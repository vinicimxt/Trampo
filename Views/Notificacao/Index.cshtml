@model List<Notificacao>

@section Styles {
    <link rel="stylesheet" href="~/css/Notificacao.css" />
}

<div class="notificacao-page">

    <h2>🔔 Notificações</h2>

    @if (Model.Count == 0)
    {
        <p>Nenhuma notificação ainda.</p>
    }
    else
    {
        <div class="notificacao-lista">
            @foreach (var n in Model)
            {
          <a href="#"
   class="notificacao-item @(n.Lida ? "lida" : "nao-lida")"
   data-id="@n.Id"
   data-ref="@(n.ReferenciaId ?? 0)"
   onclick="abrirNotificacao(event, this)">

                    <div class="notif-conteudo">
                        <strong>@n.Titulo</strong>
                        <p>@n.Mensagem</p>
                        <span class="notif-data">
                            @n.DataCriacao.ToString("dd/MM HH:mm")
                        </span>
                    </div>

                    @if (!n.Lida)
                    {
                        <div class="notif-status">
                            <span class="dot"></span>
                            <span class="badge-novo">Novo</span>
                        </div>
                    }

                </a>
            }
        </div>
    }

</div>

@section Scripts {
    <script>



    </script>

}