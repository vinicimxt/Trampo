@model List<Notificacao>

@section Styles {
    <link rel="stylesheet" href="~/css/Notificacao.css" />
}

@functions {
    string GetIcone(string tipo) {
        if (string.IsNullOrEmpty(tipo)) return "notifications";
        tipo = tipo.ToLower();
        if (tipo.Contains("agendamento")) return "event";
        if (tipo.Contains("confirmado"))  return "check_circle";
        if (tipo.Contains("cancelado"))   return "cancel";
        if (tipo.Contains("mensagem"))    return "chat";
        if (tipo.Contains("pagamento"))   return "payments";
        if (tipo.Contains("avaliacao"))   return "star";
        if (tipo.Contains("finalizado"))  return "task_alt";
        return "notifications";
    }

    string GetIconeClass(string tipo) {
        if (string.IsNullOrEmpty(tipo)) return "notif-icon-default";
        tipo = tipo.ToLower();
        if (tipo.Contains("agendamento")) return "notif-icon-agendamento";
        if (tipo.Contains("confirmado"))  return "notif-icon-confirmado";
        if (tipo.Contains("cancelado"))   return "notif-icon-cancelado";
        if (tipo.Contains("mensagem"))    return "notif-icon-mensagem";
        if (tipo.Contains("pagamento"))   return "notif-icon-pagamento";
        if (tipo.Contains("avaliacao"))   return "notif-icon-mensagem";
        if (tipo.Contains("finalizado"))  return "notif-icon-confirmado";
        return "notif-icon-default";
    }
}

@{
    int total     = Model.Count;
    int naoLidas  = Model.Count(n => !n.Lida);
}

<div class="notificacao-page">

    <!-- HERO -->
    <div class="notif-hero">
        <div class="notif-hero-dots"></div>
        <div class="notif-hero-inner">
            <div>
                <span class="notif-hero-label">Central de avisos</span>
                <h1 class="notif-hero-title">
                    <span aria-hidden="true" class="material-symbols-rounded icon-fill" style="font-size:2rem;color:var(--accent);">notifications</span>
                    Notificações
                </h1>
                <p class="notif-hero-sub">Acompanhe tudo que acontece com seus agendamentos e serviços.</p>
            </div>

            @if (naoLidas > 0)
            {
                <div class="notif-hero-badge">
                    @naoLidas
                    <span aria-label="@naoLidas mensagens não lidas">não lida@(naoLidas != 1 ? "s" : "")</span>
                </div>
            }
        </div>
    </div>

    <!-- FILTROS -->
    @if (total > 0)
    {
        <div class="notif-filters">
            <div class="notif-filters-inner">
                <button aria-label="@total notificações" class="filter-pill active" onclick="filtrarNotif('todas', this)">
                    <span aria-hidden="true" class="material-symbols-rounded" style="font-size:14px;">list</span>
                    Todas
                    <span aria-label="@total notificações">(@total)</span>
                </button>
                <button aria-label="@naoLidas mensagens não lidas" class="filter-pill" onclick="filtrarNotif('nao-lida', this)">
                    <span aria-hidden="true" class="material-symbols-rounded" style="font-size:14px;">mark_email_unread</span>
                    Não lidas
                    @if (naoLidas > 0) { <span>(@naoLidas)</span> }
                </button>
                <button class="filter-pill" onclick="filtrarNotif('lida', this)">
                    <span class="material-symbols-rounded" style="font-size:14px;">mark_email_read</span>
                    Lidas
                </button>

                @if (naoLidas > 0)
                {
                    <button class="btn-marcar-todas" onclick="marcarTodasLidas()">
                        <span class="material-symbols-rounded">done_all</span>
                        Marcar todas como lidas
                    </button>
                }
            </div>
        </div>
    }

    <!-- LISTA -->
    <div class="notif-main">

        @if (total == 0)
        {
            <div class="notif-empty-state">
                <div class="notif-empty-icon">
                    <span aria-hidden="true" class="material-symbols-rounded">notifications_off</span>
                </div>
                <h3>Nenhuma notificação ainda</h3>
                <p>Quando houver novidades sobre seus agendamentos e serviços, elas aparecerão aqui.</p>
            </div>
        }
        else
        {
            <div class="notificacao-lista" id="notifLista">

                @foreach (var n in Model)
                {
                    <a href="/Notificacao/Abrir/@n.Id?referenciaId=@n.ReferenciaId"
                       class="notificacao-item @(n.Lida ? "lida" : "nao-lida")"
                       data-lida="@(n.Lida ? "lida" : "nao-lida")">

                        <!-- ícone -->
                        <div class="notif-page-icon @GetIconeClass(n.Tipo)">
                            <span class="material-symbols-rounded icon-fill">@GetIcone(n.Tipo)</span>
                        </div>

                        <!-- conteúdo -->
                        <div class="notif-conteudo">
                            <strong>@n.Titulo</strong>
                            <p>@n.Mensagem</p>
                            <span class="notif-data">
                                <span class="material-symbols-rounded">schedule</span>
                                @n.DataCriacao.ToString("dd/MM/yyyy 'às' HH:mm")
                            </span>
                        </div>

                        <!-- status -->
                        @if (!n.Lida)
                        {
                            <div class="notif-status-col">
                                <span class="badge-novo">Novo</span>
                                <span class="dot-unread"></span>
                            </div>
                        }

                    </a>
                }

                <!-- empty filtrado -->
                <div class="notif-empty-state" id="notifEmptyFiltro" style="display:none;">
                    <div class="notif-empty-icon">
                        <span aria-hidden="true" class="material-symbols-rounded">filter_list_off</span>
                    </div>
                    <h3>Nenhuma notificação aqui</h3>
                    <p>Não há notificações com esse filtro no momento.</p>
                </div>

            </div>
        }

    </div>
</div>

@section Scripts {
<script>
    /* filtro por lida/não lida */
    function filtrarNotif(tipo, btn) {
        document.querySelectorAll('.filter-pill').forEach(function(p) {
            p.classList.remove('active');
        });
        btn.classList.add('active');

        var items = document.querySelectorAll('.notificacao-item');
        var visiveis = 0;

        items.forEach(function(item) {
            var lida = item.dataset.lida;
            var mostrar = tipo === 'todas' || lida === tipo;
            item.style.display = mostrar ? '' : 'none';
            if (mostrar) visiveis++;
        });

        var emptyFiltro = document.getElementById('notifEmptyFiltro');
        if (emptyFiltro) emptyFiltro.style.display = visiveis === 0 ? 'block' : 'none';
    }

    /* marcar todas como lidas */
    function marcarTodasLidas() {
        fetch('/Notificacao/MarcarTodasLidas', { method: 'POST' })
            .then(function() { window.location.reload(); })
            .catch(function() { window.location.reload(); });
    }
</script>
}
