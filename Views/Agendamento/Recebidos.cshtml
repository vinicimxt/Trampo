@model List<Agendamento>

@section Styles {
    <link rel="stylesheet" href="~/css/Recebidos.css" />
}

@{
    AvaliacaoDAO avalDAO = new AvaliacaoDAO();
    int usuarioId = int.Parse(Context.Session.GetString("UsuarioId"));
}

@if (TempData["Sucesso"] != null)
{
    <div class="alert-sucesso">
        <span class="material-symbols-rounded">check_circle</span>
        @TempData["Sucesso"]
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert-erro">
        <span class="material-symbols-rounded">error</span>
        @TempData["Erro"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert-info">
        <span class="material-symbols-rounded">info</span>
        @TempData["Info"]
    </div>
}

@functions {
    string GetStatusClass(string status)
    {
        if (status == "Pendente") return "status-pendente";
        if (status == "Confirmado") return "status-confirmado";
        if (status == "AguardandoCliente") return "status-aguardando";
        if (status == "Finalizado") return "status-finalizado";
        if (status == "CanceladoCliente") return "status-cancelado";
        if (status == "CanceladoProfissional") return "status-cancelado";
        return "";
    }
    string GetDataFiltro(string status)
    {
        if (status == "CanceladoCliente" || status == "CanceladoProfissional") return "cancelado";
        if (status == "AguardandoCliente") return "Finalizado";
        return status;
    }
    string GetBadgeClass(string status)
    {
        if (status == "Pendente") return "badge-pendente";
        if (status == "Confirmado") return "badge-confirmado";
        if (status == "AguardandoCliente") return "badge-aguardando";
        if (status == "Finalizado") return "badge-finalizado";
        return "badge-cancelado";
    }
    string GetBadgeTexto(string status)
    {
        if (status == "Pendente") return "Pendente";
        if (status == "Confirmado") return "Confirmado";
        if (status == "AguardandoCliente") return "Aguardando cliente";
        if (status == "Finalizado") return "Finalizado";
        if (status == "CanceladoCliente") return "Cancelado pelo cliente";
        if (status == "CanceladoProfissional") return "Cancelado por você";
        return status;
    }
    string GetIniciais(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome)) return "?";
        var partes = nome.Trim().Split(' ');
        string ini = "";
        for (int i = 0; i < partes.Length && i < 2; i++)
            if (partes[i].Length > 0) ini += char.ToUpper(partes[i][0]);
        return ini;
    }
}

@{
    int total = Model.Count;
    int pendentes = Model.Count(a => a.StatusAtual() == "Pendente");
    int confirmados = Model.Count(a => a.StatusAtual() == "Confirmado");
    int finalizados = Model.Count(a =>
        a.StatusAtual() == "Finalizado" || a.StatusAtual() == "AguardandoCliente");
    int cancelados = Model.Count(a =>
        a.StatusAtual() == "CanceladoCliente" || a.StatusAtual() == "CanceladoProfissional");
}

<div class="recebidos-page">

    <!-- HERO -->
    <div class="recebidos-hero">
        <div class="recebidos-hero-dots"></div>
        <div class="recebidos-hero-inner">

            <div>
                <span class="recebidos-hero-label">Painel do profissional</span>
                <h1 class="recebidos-hero-title">Pedidos Recebidos</h1>
                <p class="recebidos-hero-sub">Gerencie os agendamentos dos seus clientes.</p>
            </div>

            @if (total > 0)
            {
                <div class="hero-counters">
                    <div class="hero-counter">
                        <strong class="hero-counter-val">@total</strong>
                        <span class="hero-counter-lbl">Total</span>
                    </div>
                    @if (pendentes > 0)
                    {
                        <div class="hero-counter has-pending">
                            <strong class="hero-counter-val">@pendentes</strong>
                            <span class="hero-counter-lbl">Aguardando</span>
                        </div>
                    }
                    @if (confirmados > 0)
                    {
                        <div class="hero-counter">
                            <strong class="hero-counter-val" style="color:#22c55e;">@confirmados</strong>
                            <span class="hero-counter-lbl">Confirmados</span>
                        </div>
                    }
                    @if (finalizados > 0)
                    {
                        <div class="hero-counter">
                            <strong class="hero-counter-val" style="color:#8b5cf6;">@finalizados</strong>
                            <span class="hero-counter-lbl">Finalizados</span>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

    <!-- FILTROS -->
    @if (total > 0)
    {
        <div class="recebidos-filters">
            <div class="recebidos-filters-inner">

                <button class="filter-pill active" onclick="filtrar('todos', this)">
                    <span class="filter-pill-dot dot-all"></span> Todos
                </button>
                <button class="filter-pill" onclick="filtrar('Pendente', this)">
                    <span class="filter-pill-dot dot-pendente"></span>
                    Pendentes @if (pendentes > 0) {
                    <span>(@pendentes)</span>
                }
            </button>
            <button class="filter-pill" onclick="filtrar('Confirmado', this)">
                <span class="filter-pill-dot dot-confirmado"></span>
                Confirmados @if (confirmados > 0) {
                <span>(@confirmados)</span>
            }
        </button>
        <button class="filter-pill" onclick="filtrar('Finalizado', this)">
            <span class="filter-pill-dot dot-finalizado"></span>
            Finalizados @if (finalizados > 0) {
            <span>(@finalizados)</span>
        }
    </button>
    <button class="filter-pill" onclick="filtrar('cancelado', this)">
        <span class="filter-pill-dot dot-cancelado"></span>
        Cancelados @if (cancelados > 0) {
        <span>(@cancelados)</span>
    }
</button>

<span class="filter-count">
    <strong id="contadorFiltro">@total</strong> pedido(s)
</span>

</div>
</div>
    }

<!-- LISTA -->
<div class="recebidos-main">

    @if (total == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <span class="material-symbols-rounded">inbox</span>
            </div>
            <h3>Nenhum pedido recebido ainda</h3>
            <p>Quando clientes agendarem seus serviços, os pedidos aparecerão aqui para você confirmar ou recusar.</p>
        </div>
    }
    else
    {
        <div class="agend-lista" id="agendLista">

            @foreach (var ag in Model)
            {
                <div class="agend-card @GetStatusClass(ag.StatusAtual())" data-status="@GetDataFiltro(ag.StatusAtual())">

                    <!-- cabeçalho -->
                    <div class="agend-card-header">
                        <div class="agend-avatar">@GetIniciais(ag.NomeCliente)</div>

                        <div>
                            <div class="agend-cliente-name">@ag.NomeCliente</div>
                            <div class="agend-servico destaque-servico">
                                <span class="material-symbols-rounded" style="font-size:14px;">build</span>
                                @ag.Servico
                            </div>
                            @if (!string.IsNullOrEmpty(ag.Subcategoria))
                            {
                                <div class="agend-subcategoria">
                                    <span class="material-symbols-rounded" style="font-size:13px;">label</span>
                                    @ag.Subcategoria
                                </div>
                            }
                        </div>

                        <span class="status-badge @GetBadgeClass(ag.StatusAtual())">
                            <span class="badge-dot"></span>
                            @GetBadgeTexto(ag.StatusAtual())
                        </span>
                    </div>

                    <!-- corpo -->
                    <div class="agend-card-body">

                        <div class="agend-info-item">
                            <div class="agend-info-label">
                                <span class="material-symbols-rounded">calendar_month</span>
                                Data
                            </div>
                            <div class="agend-info-val">@ag.Data.ToString("dd/MM/yyyy")</div>
                            <div style="font-size:.75rem;color:var(--text-muted);margin-top:2px;">
                                @ag.Data.ToString("dddd", new System.Globalization.CultureInfo("pt-BR"))
                            </div>
                        </div>

                        <div class="agend-info-item">
                            <div class="agend-info-label">
                                <span class="material-symbols-rounded">schedule</span>
                                Horário
                            </div>
                            <div class="agend-info-val">@ag.Hora</div>
                        </div>

                        <div class="agend-info-item">
                            <div class="agend-info-label">
                                <span class="material-symbols-rounded">payments</span>
                                Preço
                            </div>
                            <div class="agend-info-val">
                                @if (ag.TipoPreco == "Fixo")
                                {
                                    <span class="valor-fixo">
                                        R$ @ag.PrecoBase
                                    </span>
                                }
                                else
                                {
                                    <span class="valor-combinar">
                                        A combinar
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="agend-info-item">
                            <div class="agend-info-label">
                                <span class="material-symbols-rounded">place</span>
                                Atendimento
                            </div>
                            <div class="agend-info-val">
                                @if (ag.Atendimento == "Local")
                                {
                                    <span class="agend-atend-chip chip-local">
                                        <span class="material-symbols-rounded">location_on</span>
                                        Presencial
                                    </span>
                                }
                                else if (ag.Atendimento == "Domicilio")
                                {
                                    <span class="agend-atend-chip chip-domicilio">
                                        <span class="material-symbols-rounded">home</span>
                                        Domicílio
                                    </span>
                                }
                                else if (ag.Atendimento == "Online")
                                {
                                    <span class="agend-atend-chip chip-online">
                                        <span class="material-symbols-rounded">laptop</span>
                                        Online
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="agend-info-item">
                            <div class="agend-info-val">
                                @if (ag.ConfirmadoProfissional)
                                {
                                    <div class="ag-contato">
                                        <span class="material-symbols-rounded"
                                              style="font-size:15px;color:var(--blue);">call</span>
                                        <span>@ag.ContatoCliente</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="aguardando-chip">
                                        <span class="material-symbols-rounded" style="font-size:14px;">lock</span>
                                        Contato liberado após confirmação
                                    </span>
                                }
                            </div>
                        </div>

                    </div>

                    <!-- área de ações -->
                    <div class="agend-actions-area">

                        <!-- endereço / link -->
                        <div class="agend-info-extra">
                            @if (ag.Atendimento == "Domicilio")
                            {
                                if (ag.ConfirmadoProfissional && !string.IsNullOrEmpty(ag.EnderecoCliente))
                                {
                                    <span class="material-symbols-rounded" style="font-size:16px;">home</span>
                                    <span>@ag.EnderecoCliente</span>
                                }
                                else
                                {
                                    <span class="aguardando-chip">
                                        <span class="material-symbols-rounded" style="font-size:14px;">lock</span>
                                        Endereço visível após confirmação
                                    </span>
                                }
                            }
                            else if (ag.Atendimento == "Online" && !string.IsNullOrEmpty(ag.LinkOnline))
                            {
                                <a href="@ag.LinkOnline" target="_blank" class="btn-link-online">
                                    <span class="material-symbols-rounded" style="font-size:16px;">video_call</span>
                                    Acessar reunião
                                </a>
                            }
                            else if (ag.Atendimento == "Local" && !string.IsNullOrEmpty(ag.EnderecoLocal))
                            {
                                <span class="material-symbols-rounded" style="font-size:16px;">location_on</span>
                                <span>@ag.EnderecoLocal</span>
                            }
                        </div>

                        <!-- botões -->
                        <div class="agend-btns">

                            @if (ag.StatusAtual() == "Pendente")
                            {
                                <button class="btn-confirmar"
                                        onclick="abrirModal('confirmar', '@ag.Id',
                                    '@ag.NomeCliente.Replace("'", "\\'")',
                                    '@ag.Data.ToString("dd/MM/yyyy")',
                                    '@ag.Hora',
                                    '@ag.TipoPreco',
                                    '@ag.PrecoBase')">
                                    <span class="material-symbols-rounded">check_circle</span>
                                    Confirmar
                                </button>
                                <button class="btn-recusar"
                                        onclick="abrirModal('recusar', '@ag.Id',
                                    '@ag.NomeCliente.Replace("'", "\\'")',
                                    '@ag.Data.ToString("dd/MM/yyyy")',
                                    '@ag.Hora',
                                    '@ag.TipoPreco',
                                    '@ag.PrecoBase')">
                                    <span class="material-symbols-rounded">cancel</span>
                                    Recusar
                                </button>
                            }
                            else if (ag.StatusAtual() == "Confirmado")
                            {
                                <button class="btn-finalizar" onclick="abrirModal(
                                    'finalizar',
                                    '@ag.Id',
                                    '@ag.NomeCliente.Replace("'", "\\'")',
                                    '@ag.Data.ToString("dd/MM/yyyy")',
                                    '@ag.Hora',
                                    '@ag.TipoPreco',
                                    '@ag.PrecoBase',
                                    '@(ag.PlanoProfissional == "Premium" ? 4 : 10)'
                                    )">
                                    <span class="material-symbols-rounded">task_alt</span>
                                    Finalizar
                                </button>
                            }
                            else if (ag.StatusAtual() == "AguardandoCliente")
                            {
                                <span class="status-info">
                                    <span class="material-symbols-rounded" style="font-size:15px;">hourglass_top</span>
                                    Aguardando confirmação do cliente
                                </span>
                            }
                            else if (ag.StatusAtual() == "Finalizado")
                            {
                                <span class="status-finalizado">
                                    <span class="material-symbols-rounded">
                                        verified
                                    </span>

                                    Serviço finalizado

                                    @if (ag.ValorFinal.HasValue)
                                    {
                                        <strong>
                                            • R$ @ag.ValorFinal.Value.ToString("F2")
                                        </strong>
                                    }
                                </span>
                            }

                            @if (ag.StatusAtual() == "Pendente" || ag.StatusAtual() == "Confirmado")
                            {
                                <button class="btn-cancelar-pro"
                                        onclick="abrirModal('cancelar', '@ag.Id', '@ag.NomeCliente.Replace("'", "\\'")', '@ag.Data.ToString("dd/MM/yyyy")', '@ag.Hora')">
                                    <span class="material-symbols-rounded">close</span>
                                    Cancelar
                                </button>
                            }

                        </div>

                    </div>

                </div>
            }

            <div class="empty-filtrado" id="emptyFiltrado">
                Nenhum pedido com esse status.
            </div>

        </div>
    }

</div>
</div>


<!-- Modal Confirmar -->
<div class="modal-overlay" id="modalConfirmar">
    <div class="modal-box">
        <div class="modal-icon">
            <span class="material-symbols-rounded icon-fill" style="font-size:2.8rem;color:#22c55e;">check_circle</span>
        </div>
        <div class="modal-title">Confirmar agendamento?</div>
        <p class="modal-sub" id="descConfirmar"></p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="fecharModais()">Voltar</button>
            <a class="btn-modal-green" id="linkConfirmar" href="#">
                <span class="material-symbols-rounded">check</span>
                Sim, confirmar
            </a>
        </div>
    </div>
</div>

<!-- Modal Recusar -->
<div class="modal-overlay" id="modalRecusar">
    <div class="modal-box">
        <div class="modal-icon">
            <span class="material-symbols-rounded icon-fill" style="font-size:2.8rem;color:#ef4444;">cancel</span>
        </div>
        <div class="modal-title">Recusar pedido?</div>
        <p class="modal-sub" id="descRecusar"></p>
        <div id="areaValorFinal" style="display:none; margin-top:20px;">

            <label style="display:block;margin-bottom:8px;font-weight:600;">
                Valor do serviço
            </label>

            <input type="number" step="0.01" min="1" id="valorFinalInput" placeholder="Ex: 120.00" style="
            width:100%;
            padding:12px;
            border-radius:12px;
            border:none;
            outline:none;
            " />

        </div>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="fecharModais()">Voltar</button>
            <a class="btn-modal-red" id="linkRecusar" href="#">
                <span class="material-symbols-rounded">close</span>
                Sim, recusar
            </a>
        </div>
    </div>
</div>

<!-- Modal Finalizar -->
<div class="modal-overlay" id="modalFinalizar">

    <div class="modal-box">

        <div class="modal-icon">
            <span class="material-symbols-rounded icon-fill" style="font-size:2.8rem;color:#22c55e;">
                task_alt
            </span>
        </div>

        <div class="modal-title">
            Finalizar atendimento?
        </div>

        <p class="modal-sub" id="descFinalizar"></p>

        <form method="post" action="/Agendamento/Finalizar">

            <input type="hidden" name="id" id="finalizarId">

            <div id="containerPreco"></div>

            <div class="modal-actions">

                <button type="button" class="btn-modal-cancel" onclick="fecharModais()">
                    Voltar
                </button>

                <button type="submit" class="btn-modal-green">

                    <span class="material-symbols-rounded">
                        check
                    </span>

                    Finalizar

                </button>

            </div>

        </form>
    </div>

</div>
<!-- Modal Cancelar -->
<div class="modal-overlay" id="modalCancelar">
    <div class="modal-box">
        <div class="modal-icon">
            <span class="material-symbols-rounded icon-fill" style="font-size:2.8rem;color:#ef4444;">warning</span>
        </div>
        <div class="modal-title">Cancelar agendamento?</div>
        <p class="modal-sub" id="descCancelar"></p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="fecharModais()">Manter</button>
            <form id="formCancelar" asp-action="Cancelar" method="post" style="flex:1;">
                <input type="hidden" name="id" id="cancelarId" />
                <button type="submit" class="btn-modal-red" style="width:100%;">
                    <span class="material-symbols-rounded">close</span>
                    Sim, cancelar
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filtrar(status, btn) {
            document.querySelectorAll('.filter-pill').forEach(function (p) { p.classList.remove('active'); });
            btn.classList.add('active');
            var cards = document.querySelectorAll('.agend-card');
            var n = 0;
            cards.forEach(function (c) {
                var show = status === 'todos' || c.dataset.status === status;
                c.style.display = show ? '' : 'none';
                if (show) n++;
            });
            var cnt = document.getElementById('contadorFiltro');
            if (cnt) cnt.textContent = n;
            var emp = document.getElementById('emptyFiltrado');
            if (emp) emp.classList.toggle('visivel', n === 0);
        }

        function abrirModal(tipo, id, cliente, data, hora, tipoPreco, precoBase, percentualTaxa) {
            fecharModais();
            
            precoBase = parseFloat(
                precoBase.toString().replace(',', '.')
            );

            percentualTaxa = parseFloat(percentualTaxa);

            let taxa =
                precoBase * (percentualTaxa / 100);

            let liquido =
                precoBase - taxa;

            var desc = 'Agendamento de <strong>' + cliente + '</strong> para <strong>' + data + ' às ' + hora + '</strong>.';

            if (tipo === 'confirmar') {
                document.getElementById('descConfirmar').innerHTML = desc;
                document.getElementById('linkConfirmar').href = '/Agendamento/Confirmar/' + id;
                document.getElementById('modalConfirmar').classList.add('open');
            }
            else if (tipo === 'recusar') {
                document.getElementById('descRecusar').innerHTML = desc + ' O cliente será notificado.';
                document.getElementById('linkRecusar').href = '/Agendamento/Recusar/' + id;
                document.getElementById('modalRecusar').classList.add('open');
            }
            else if (tipo === 'finalizar') {

                document.getElementById('descFinalizar').innerHTML =
                    desc + ' Confirme que o serviço foi realizado.';

                document.getElementById('finalizarId').value = id;

                let htmlPreco = '';

                // SERVIÇO COM PREÇO FIXO
                if (tipoPreco === 'Fixo') {

                    htmlPreco = `
                                                <div style="margin-top:20px;text-align:left;">

                                                    <label style="font-weight:600;">
                                                        Valor do serviço
                                                    </label>

                                                    <input
                                                        type="number"
                                                        name="valorFinal"
                                                        value="${precoBase}"
                                                        readonly
                                                        class="input-valor-final"
                                                        style="
                                                            width:100%;
                                                            margin-top:8px;
                                                            padding:12px;
                                                            border-radius:12px;
                                                            border:none;
                                                            outline:none;
                                                        "
                                                    />

                                                </div>

                                                  <div class="resumo-financeiro">

                                                    <div class="resumo-item">
                                                        Taxa da plataforma (${percentualTaxa}%):
                                                        <strong>R$ ${taxa.toFixed(2)}</strong>
                                                    </div>

                                                    <div class="resumo-item destaque">
                                                        Você receberá:
                                                        <strong>R$ ${liquido.toFixed(2)}</strong>
                                                    </div>

                                                </div>
                                            `;
                }

                // SERVIÇO A COMBINAR
                else {

                    htmlPreco = `
                                                <div style="margin-top:20px;text-align:left;">

                                                    <label style="font-weight:600;">
                                                        Valor cobrado
                                                    </label>

                                                    <input
                                                        type="number"
                                                        name="valorFinal"
                                                        step="0.01"
                                                        min="1"
                                                        required
                                                        placeholder="Ex: 120.00"
                                                        class="input-valor-final"
                                                        style="
                                                            width:100%;
                                                            margin-top:8px;
                                                            padding:12px;
                                                            border-radius:12px;
                                                            border:none;
                                                            outline:none;
                                                        "
                                                    />

                                                </div>
                                            `;
                }

                document.getElementById('containerPreco').innerHTML = htmlPreco;

                document.getElementById('modalFinalizar')
                    .classList.add('open');
            }
            else if (tipo === 'cancelar') {
                document.getElementById('descCancelar').innerHTML = desc + ' Esta ação não pode ser desfeita.';
                document.getElementById('cancelarId').value = id;
                document.getElementById('modalCancelar').classList.add('open');
            }
        }

        function fecharModais() {
            document.querySelectorAll('.modal-overlay').forEach(function (m) {
                m.classList.remove('open');
            });
        }

        document.querySelectorAll('.modal-overlay').forEach(function (m) {
            m.addEventListener('click', function (e) { if (e.target === this) fecharModais(); });
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') fecharModais();
        });



        function calcularResumoFinanceiro(percentual) {

            let valor = parseFloat(
                document.getElementById('valorFinalInput').value
            );

            if (!valor || valor <= 0) {
                document.getElementById('resumoFinanceiro').style.display = 'none';
                return;
            }

            let taxa = valor * (percentual / 100);
            let liquido = valor - taxa;

            document.getElementById('resumoFinanceiro').style.display = 'block';

            document.getElementById('taxaTexto').innerText =
                'R$ ' + taxa.toFixed(2);

            document.getElementById('liquidoTexto').innerText =
                'R$ ' + liquido.toFixed(2);
        }


    </script>
}
