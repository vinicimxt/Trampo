<h2>Meus Agendamentos</h2>

<table>
    <thead>
        <tr>
            <th>Profissional</th>
            <th>Data</th>
            <th>Hora</th>
            <th>Serviço</th>
            <th>Status</th>
            <th>Ação</th>
            <th>Link Online</th>
            <th>Local de Atendimento</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var ag in Model)
        {
            <tr>
                
                <td>@ag.NomeProfissional</td>
                <td>@ag.Data.ToShortDateString()</td>
                <td>@ag.Hora</td>
                <td>@ag.Servico</td>

                
                <td>
                    @{
                        string statusTexto = ag.Status switch
                        {
                            "Pendente" => "🟡 Pendente",
                            "Confirmado" => "🟢 Confirmado",
                            "Finalizado" => "🔵 Finalizado",
                            "CanceladoCliente" => "🔴 Cancelado por você",
                            "CanceladoProfissional" => "🔴 Cancelado pelo profissional",
                            _ => ag.Status
                        };
                    
                    }

                    @statusTexto
                </td>

                
      
                <td>
                    @if (ag.Status == "Pendente" || ag.Status == "Confirmado")
                    {
                        <form asp-action="Cancelar" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@ag.Id" />
                            <button type="submit">Cancelar</button>
                        </form>
                    }

                 
                </td>
                
                <td>
                    @if (!string.IsNullOrEmpty(ag.LinkOnline))
                    {
                        <div>
                            @if (ag.Status == "Confirmado")
                            {
                                <a href="@ag.LinkOnline" target="_blank">🔗 Entrar</a>
                            }
                            else
                            {
                                <span>🔒 Aguarde confirmação</span>
                            }
                        </div>
                    }
                </td>

                <td>
                    @if (!string.IsNullOrEmpty(ag.EnderecoLocal))
                    {
                        @ag.EnderecoLocal
                    }
                    else
                    {
                        <span>Não informado</span>
                    }
                </td>

                
            </tr>
     
        }
    </tbody>
</table>