@section Styles {
    <link rel="stylesheet" href="~/css/login.css" />
}

<div class="auth-container">
    <div class="auth-card">

        <div class="auth-header">
            <h2>Login</h2>
            <p>Entre na sua conta</p>
        </div>

        <form method="post" asp-action="Logar" class="auth-form" id="loginForm">

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" id="email" placeholder="seu@email.com" required />
                <span class="error-text" id="emailError"></span>
            </div>

            <div class="form-group password-group">
                <label>Senha</label>

                <div class="password-wrap">
                    <input type="password" name="senha" id="senha" placeholder="••••••••" required />
                    <button type="button" class="toggle-pass" id="toggleSenha">👁</button>
                </div>

                <span class="error-text" id="senhaError"></span>
            </div>

            <button type="submit" class="btn-auth" id="btnLogin">
                Entrar
            </button>

        </form>

        <div class="auth-footer">
            <span>Não tem conta?</span>
            <a asp-controller="Usuario" asp-action="Cadastro">Criar conta</a>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/login.js"></script>
}