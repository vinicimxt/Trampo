@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="auth-page">

    <!-- PAINEL ESQUERDO -->
    <div class="auth-panel">
        <div class="auth-panel-dots"></div>

        <div class="auth-panel-content">
            <div class="auth-logo">
                <img src="~/assets/imagens/Trampo-Logo.png" alt="Trampo Logo" class="logo-img">
                Tram<span class="highlight">po</span>
            </div>
            <h1 class="auth-panel-title">
                Bem-vindo<br>de volta!
            </h1>
            <p class="auth-panel-sub">
                Entre na sua conta e acesse os melhores profissionais ou gerencie seus agendamentos.
            </p>

            <div class="auth-bullets">
                <div class="auth-bullet">
                    <div class="auth-bullet-icon">
                        <span class="material-symbols-rounded icon-fill">bolt</span>
                    </div>
                    <span class="auth-bullet-text">Acesse sua agenda em segundos</span>
                </div>
                <div class="auth-bullet">
                    <div class="auth-bullet-icon">
                        <span class="material-symbols-rounded icon-fill">notifications_active</span>
                    </div>
                    <span class="auth-bullet-text">Veja notificações de novos agendamentos</span>
                </div>
                <div class="auth-bullet">
                    <div class="auth-bullet-icon">
                        <span class="material-symbols-rounded icon-fill">bar_chart</span>
                    </div>
                    <span class="auth-bullet-text">Acompanhe seu histórico completo</span>
                </div>
            </div>
        </div>

        <div class="auth-panel-footer">
            © 2026 Trampo — Todos os direitos reservados
        </div>
    </div>

    <!-- PAINEL DIREITO -->
    <div class="auth-form-side">
        <div class="auth-card">

            <div class="auth-card-header">
                <span class="auth-card-label">Acesso seguro</span>
                <h2 class="auth-card-title">Entrar na conta</h2>
                <p class="auth-card-sub">Informe suas credenciais para continuar.</p>
            </div>

            <form method="post" asp-action="Logar" id="loginForm" novalidate>

                <!-- Email -->
                <div class="form-group">
                    <label class="form-label" for="email">E-mail</label>
                    <div class="input-icon-wrap">
                        <span class="input-icon">
                            <span class="material-symbols-rounded">mail</span>
                        </span>
                        <input class="form-input has-icon" type="email"
                               name="email" id="email"
                               placeholder="seu@email.com"
                               required autocomplete="email" />
                    </div>
                    <span class="input-message" id="emailError"></span>
                </div>

                <!-- Senha -->
                <div class="form-group">
                    <label class="form-label" for="senha">Senha</label>
                    <div class="password-wrap">
                        <span class="input-icon">
                            <span class="material-symbols-rounded">lock</span>
                        </span>
                        <input class="form-input has-icon" type="password"
                               name="senha" id="senha"
                               placeholder="••••••••"
                               required autocomplete="current-password" />
                        <button type="button" class="toggle-pass" id="toggleSenha"
                                aria-label="Mostrar senha">
                            <span class="material-symbols-rounded" id="toggleIcon">visibility</span>
                        </button>
                    </div>
                    <span class="input-message" id="senhaError"></span>
                </div>

                <button type="submit" class="btn-auth" id="btnLogin">
                    <span class="material-symbols-rounded">login</span>
                    Entrar na conta
                </button>

            </form>

            <div class="auth-switch">
                Não tem conta?
                <a asp-controller="Usuario" asp-action="Cadastro">Criar conta grátis</a>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/login.js"></script>
}