<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <title>Xamou</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css?v=4" />
    @RenderSection("Styles", required: false)

</head>

<body>

    
    <div id="toast-container"></div>


    <header class="navbar" id="navbar">

        <div class="container-ap nav-wrapper">

            <a href="/#home" class="a-logo">
                <!-- LOGO -->
                <div class="logo">
                    <img src="~/assets/imagens/Trampo-Logo.png" alt="Trampo Logo" class="logo-img">
                        <span>Tram<span class="highlight">po</span></span>
                    </div>
                </a>
                <!-- MENU -->
                <nav class="nav-links" id="navLinks">
                    <a href="/#home" class="nav-item">Home</a>
                    <a href="/#why" class="nav-item">Por que Trampo?</a>
                    <a href="/#about" class="nav-item">Sobre nós</a>
                    <a href="/#how" class="nav-item">Como funciona</a>
                    <a href="/#services" class="nav-item">Serviços</a>
                    <a href="/#reviews" class="nav-item">Avaliações</a>
                    <a asp-controller="Profissional" asp-action="Lista" class="nav-item">Profissionais</a>

                    @if (Context.Session.GetString("UsuarioNome") != null)
                    {
                        <a asp-controller="Agendamento" asp-action="Meus" class="nav-item">Agendamentos</a>
                    }
                
                </nav>

                <!-- USER AREA -->
                <div class="nav-right">

                    @{
                        var nome = Context.Session.GetString("UsuarioNome");
                        var tipo = Context.Session.GetString("UsuarioTipo");
                    }

                    
                    @if (nome != null)
                    {
                        <span class="user">Olá, @nome</span>
                        
                        <div class="notif-wrapper">
                            <div class="notif-icon" id="notifToggle">
                                <span class="material-symbols-rounded">notifications</span>

                                @if (ViewBag.NotifCount != null && ViewBag.NotifCount > 0)
                                {
                                    <span class="notif-badge">@ViewBag.NotifCount</span>
                                }
                            </div>

                            <!-- DROPDOWN -->
                            <div class="notif-dropdown" id="notifDropdown">
                                <div class="notif-header">
                                    Notificações
                                </div>

                                <div class="notif-list" id="notifList">
                                    <p class="notif-empty">Carregando notificações...</p>
                                </div>

                                <a href="/Notificacao" class="ver-todas">
                                    Ver todas →
                                </a>
                            </div>
                        </div>

                        @if (tipo == "profissional")
                        {
                            <a asp-controller="Profissional" asp-action="MeuPerfil" class="btn-outline">
                                Painel
                            </a>
                        }

                        <a asp-controller="Usuario" asp-action="Logout" class="btn-logout">
                            Sair
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Usuario" asp-action="Login" class="btn-outline">
                            Login
                        </a>

                        <a asp-controller="Usuario" asp-action="Cadastro" class="btn-criar">
                            Criar Conta
                        </a>
                    }

                    <!-- MOBILE BTN -->
                    <button class="menu-toggle" id="menuToggle">
                        ☰
                    </button>

                </div>

            </div>

        </header>
        
        <main>
            @RenderBody()
        </main>

        <button id="btnTop" class="btn-top">
            ↑
        </button>

        <script src="~/js/site.js"></script>

        @if (TempData["Sucesso"] != null)
        {
            <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        showToast("@TempData["Sucesso"]", "success");
                    });
            </script>
        }

        @if (TempData["Erro"] != null)
        {
            <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        showToast("@TempData["Erro"]", "error");
                    });
            </script>
        }


        @RenderSection("Scripts", required: false)

        <div class="modal-overlay" id="modalGlobal">
            <div class="modal-drawer">
                <div class="drawer-header">
                    <h3>Detalhes</h3>
                    <button onclick="fecharModal('modalGlobal')">✕</button>
                </div>

                <div class="modal-body"></div>
            </div>
        </div>

    </body>

</html>