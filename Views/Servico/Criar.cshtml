@model Servico

<h2>Novo Serviço</h2>

<form asp-action="Criar" asp-controller="Servico" method="post">

    <input type="text" name="Nome" placeholder="Nome do serviço" required />

    <textarea name="Descricao" placeholder="Descrição"></textarea>

    <input type="text" name="Contato" placeholder="Contato" />

    <label>Atendimento</label>
    <select name="Atendimento">
        <option value="Domicilio">Domicílio</option>
        <option value="Local">Local fixo</option>
        <option value="Online">Online</option>
    </select>

    <label>Raio (km)</label>
    <input type="number" name="Raio" />

    <button type="submit">Salvar</button>

</form>