@model Servico

@section Styles {
    <link rel="stylesheet" href="~/css/servico.css" />
}

<div class="servico-page">

    <!-- HERO -->
    <div class="servico-hero">
        <div class="servico-hero-dots"></div>
        <div class="servico-hero-inner">
            <span class="servico-hero-label">Novo serviço</span>
            <h1 class="servico-hero-title">Criar Serviço</h1>
            <p class="servico-hero-sub">Preencha as informações e comece a receber agendamentos.</p>
        </div>
    </div>

    <!-- ALERTAS -->
    @if (TempData["Erro"] != null)
    {
        <div class="alert">
            <div class="alert-inner erro">⚠️ @TempData["Erro"]</div>
        </div>
    }
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert">
            <div class="alert-inner sucesso">✅ @TempData["Sucesso"]</div>
        </div>
    }

    <!-- LAYOUT -->
    <div class="servico-main">

        <!-- ============================================
             FORMULÁRIO (coluna esquerda)
        ============================================= -->
        <div class="form-card">

            <div class="form-card-header">
                <div class="form-card-header-icon">🛠</div>
                <div>
                    <h2>Informações do Serviço</h2>
                    <p>Quanto mais detalhes, mais clientes você atrai</p>
                </div>
            </div>

            <form method="post" action="/Servico/Salvar" id="formServico" class="form-body">

                <!-- SEÇÃO: Classificação -->
                <div class="form-section-label">Classificação</div>

                <div class="form-group">
                    <label class="form-label" for="categoria">
                        Categoria <span class="req">*</span>
                    </label>
                    <div class="select-wrap">
                        <select id="categoria" class="form-select">
                            <option value="">Selecione uma categoria</option>
                            @foreach (var c in ViewBag.Categorias)
                            {
                                <option value="@c.Id">@c.Nome</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="subcategoria">
                        Subcategoria <span class="req">*</span>
                    </label>
                    <div class="select-wrap">
                        <select id="subcategoria" name="subcategoriaId" class="form-select" required>
                            <option value="">Selecione a categoria primeiro</option>
                        </select>
                    </div>
                </div>

                <!-- SEÇÃO: Detalhes -->
                <div class="form-section-label" style="margin-top:8px;">Detalhes</div>

                <div class="form-group">
                    <label class="form-label" for="nome">
                        Nome do serviço <span class="req">*</span>
                    </label>
                    <input type="text" name="nome" id="nome" class="form-input"
                           placeholder="Ex: Corte de cabelo masculino" required />
                    <span class="input-msg" id="nomeMsg"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="descricao">
                        Descrição <span class="opt">(opcional)</span>
                    </label>
                    <textarea name="descricao" id="descricao" class="form-textarea" maxlength="200"
                              placeholder="Descreva o que está incluído, diferenciais, tempo de atendimento..."></textarea>
                    <div class="char-count" id="charCount">0 / 200</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="contato">
                        Contato <span class="opt">(opcional)</span>
                    </label>
                    <input type="text" name="contato" id="contato" class="form-input" placeholder="(11) 91234-5678" />
                </div>

                <!-- SEÇÃO: Atendimento -->
                <div class="form-section-label" style="margin-top:8px;">Atendimento</div>

                <div class="form-group">
                    <label class="form-label" for="atendimento">Tipo de atendimento</label>
                    <div class="select-wrap">
                        <select name="atendimento" id="atendimento" class="form-select">
                            <option value="Domicilio">🏠 Domicílio — vou até o cliente</option>
                            <option value="Local">📍 Local — cliente vem até mim</option>
                            <option value="Online">💻 Online — atendimento remoto</option>
                        </select>
                    </div>
                </div>

                <!-- Campo dinâmico: Local -->
                <div id="localDiv" class="form-group hidden">
                    <label class="form-label">Local de atendimento</label>

                    @if (ViewBag.Locais == null || ViewBag.Locais.Count == 0)
                    {
                        <div class="alerta-local">
                            <span>⚠️ Você ainda não cadastrou nenhum local.</span>
                            <a href="/Local?abrir=true" target="_blank" class="btn-criar-local">
                                + Cadastrar local
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="select-wrap">
                            <select name="localId" class="form-select">
                                <option value="">Selecione o local</option>
                                @foreach (var l in ViewBag.Locais)
                                {
                                    <option value="@l.Id">@l.Nome — @l.Endereco</option>
                                }
                            </select>
                        </div>
                    }
                </div>

                <!-- Campo dinâmico: Link online -->
                <div id="linkOnlineDiv" class="form-group hidden">
                    <label class="form-label" for="linkOnline">Link de acesso</label>
                    <input type="url" name="linkOnline" id="linkOnline" class="form-input"
                           placeholder="https://meet.google.com/..." />
                </div>

                <!-- BOTÃO SUBMIT -->
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <span id="btnText">Criar Serviço 🚀</span>
                    <span id="btnLoader" class="loader hidden"></span>
                </button>

            </form>
        </div>

        <!-- ============================================
             PAINEL DIREITO — preview + dicas
        ============================================= -->
        <div class="side-panel">

            <!-- Preview ao vivo -->
            <div class="preview-card">
                <div class="preview-header">
                    <div class="preview-header-dot"></div>
                    <span class="preview-header-label">Preview ao vivo</span>
                </div>

                <div class="preview-body">
                    <p style="font-size:.75rem;color:var(--text-muted);margin-bottom:12px;">
                        Assim seu serviço aparecerá para os clientes:
                    </p>

                    <div class="preview-service-card">
                        <div class="prev-nome" id="previewNome">Nome do serviço</div>
                        <div class="prev-desc" id="previewDesc">A descrição aparecerá aqui...</div>

                        <div class="prev-tags">
                            <span class="prev-tag cat" id="previewCategoria">Categoria</span>
                            <span class="prev-tag atend" id="previewAtendimento">🏠 Domicílio</span>
                        </div>

                        <div class="prev-contato" id="previewContato" style="display:none;">
                            📞 <span id="previewContatoVal"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dicas -->
            <div class="tip-card">
                <div class="tip-card-title">💡 Dicas para atrair mais clientes</div>

                <div class="tip-item">
                    <div class="tip-icon">✍️</div>
                    <span>Use um nome claro e específico. "Corte masculino degradê" converte mais que só "Corte".</span>
                </div>
                <div class="tip-item">
                    <div class="tip-icon">📝</div>
                    <span>Preencha a descrição com o que está incluído e o tempo médio de atendimento.</span>
                </div>
                <div class="tip-item">
                    <div class="tip-icon">📞</div>
                    <span>Adicione um contato para clientes tirarem dúvidas antes de agendar.</span>
                </div>
                <div class="tip-item">
                    <div class="tip-icon">📍</div>
                    <span>Escolha o tipo de atendimento correto — isso aparece nos filtros de busca.</span>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/servico.js"></script>
}
