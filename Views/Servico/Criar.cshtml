@model Servico

<h2>Novo Serviço</h2>

<form method="post" action="/Servico/Salvar">

    <label>Categoria:</label>
    <select id="categoria">
        <option value="">Selecione</option>
        @foreach (var c in ViewBag.Categorias)
        {
            <option value="@c.Id">@c.Nome</option>
        }
    </select>

    <label>Subcategoria:</label>
    <select id="subcategoria" name="subcategoriaId" required>
        <option value="">Selecione a subcategoria</option>
    </select>
    
    <label>Nome do Serviço:</label>
    <input type="text" name="nome" required />

    <label>Descrição:</label>
    <textarea name="descricao"></textarea>

    <label>Contato:</label>
    <input type="text" name="contato" />

    <label>Tipo de Atendimento:</label>
    <select name="atendimento" id="atendimento">
        <option value="Domicilio">Domicílio</option>
        <option value="Local">Local</option>
        <option value="Online">Online</option>
    </select>

    <!-- 🔥 LOCAL -->
    <div id="localDiv" style="display:none;">
        <label>Local de Atendimento:</label>
        <select name="localId">
            <option value="">Selecione</option>

            @foreach (var l in ViewBag.Locais)
            {
                <option value="@l.Id">@l.Nome - @l.Endereco</option>
            }
        </select>
    </div>

    <!-- 🔥 ONLINE -->
    <div id="linkOnlineDiv" style="display:none;">
        <label>Link do atendimento:</label>
        <input type="text" name="linkOnline" placeholder="Link do atendimento online..." />
    </div>

    <button type="submit">Cadastrar</button>

</form>

<script>
    // 🔥 Subcategorias dinâmicas
    document.getElementById("categoria").addEventListener("change", function () {
        let categoriaId = this.value;

        fetch('/Servico/GetSubcategorias?categoriaId=' + categoriaId)
            .then(res => res.json())
            .then(data => {
                let sub = document.getElementById("subcategoria");

                sub.innerHTML = '<option value="">Selecione a subcategoria</option>';

                data.forEach(s => {
                    sub.innerHTML += `<option value="${s.id}">${s.nome}</option>`;
                });
            });
    });

    // 🔥 CONTROLE DE EXIBIÇÃO
    function toggleCampos() {
        let tipo = document.getElementById("atendimento").value.toLowerCase();

        let linkDiv = document.getElementById("linkOnlineDiv");
        let localDiv = document.getElementById("localDiv");

        linkDiv.style.display = (tipo === "online") ? "block" : "none";
        localDiv.style.display = (tipo === "local") ? "block" : "none";
    }

    // 🔥 muda ao trocar
    document.getElementById("atendimento").addEventListener("change", toggleCampos);

    // 🔥 roda ao carregar (ESSENCIAL)
    document.addEventListener("DOMContentLoaded", function () {
        toggleCampos();
    });
</script>