@model List<Servico>

@section Styles {
    <link rel="stylesheet" href="~/css/MeusServicos.css" />
}

@functions {
    string GetBadgeClass(string atend)
    {
        if (atend == "Local") return "badge-local";
        if (atend == "Domicilio") return "badge-domicilio";
        if (atend == "Online") return "badge-online";
        return "badge-default";
    }
    string GetBadgeIcon(string atend)
    {
        if (atend == "Local") return "📍";
        if (atend == "Domicilio") return "🏠";
        if (atend == "Online") return "💻";
        return "📌";
    }
    string GetIniciais(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome)) return "?";
        var p = nome.Trim().Split(' ');
        string r = "";
        for (int i = 0; i < p.Length && i < 2; i++)
            if (p[i].Length > 0) r += char.ToUpper(p[i][0]);
        return r;
    }
}

<div class="servicos-page">

    <!-- HERO -->
    <div class="servicos-hero">
        <div class="servicos-hero-dots"></div>
        <div class="servicos-hero-inner">
            <div>
                <span class="servicos-hero-label">Meu negócio</span>
                <h1 class="servicos-hero-title">Meus Serviços</h1>
                <p class="servicos-hero-sub">Gerencie, edite e organize tudo que você oferece.</p>
            </div>
            @if (Model.Count > 0)
            {
                <div class="servicos-hero-count">
                    <strong>@Model.Count</strong>
                    <span>@(Model.Count == 1 ? "serviço cadastrado" : "serviços cadastrados")</span>
                </div>
            }
        </div>
    </div>

    <!-- CONTEÚDO -->
    <div class="servicos-main">

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>Nenhum serviço cadastrado</h3>
                <p>Crie seu primeiro serviço para aparecer para clientes e começar a receber agendamentos.</p>
                <a href="/Servico/Criar" class="btn-criar-primeiro">+ Criar meu primeiro serviço</a>
            </div>
        }
        else
        {
            <div class="servicos-topbar">
                <div class="servicos-topbar-title">Todos os serviços</div>
                <a href="/Servico/Criar" class="btn-novo">+ Novo serviço</a>
            </div>

            <div class="servicos-layout" id="servicosLayout">

                <!-- COLUNA DA LISTA -->
                <div>
                    <div class="servicos-grid" id="servicosGrid">
                        @foreach (var s in Model)
                        {
                            <div class="servico-card" id="card-@s.Id">

                                <div class="servico-header">
                                    <h3>@s.Nome</h3>
                                    <span class="badge-atendimento @GetBadgeClass(s.Atendimento)">
                                        @GetBadgeIcon(s.Atendimento) @s.Atendimento
                                    </span>
                                </div>

                                <div class="servico-body">

                                    <div class="info-row">
                                        <div class="info-row-icon">📂</div>
                                        <div>
                                            <span class="info-row-label">Categoria</span>
                                            <div class="info-row-val">@s.Categoria</div>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(s.Subcategoria))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">🏷️</div>
                                            <div>
                                                <span class="info-row-label">Subcategoria</span>
                                                <div class="info-row-val">@s.Subcategoria</div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.Contato))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">📞</div>
                                            <div>
                                                <span class="info-row-label">Contato</span>
                                                <div class="info-row-val">@s.Contato</div>
                                            </div>
                                        </div>
                                    }

                                    @if (s.Atendimento == "Local" && !string.IsNullOrEmpty(s.Endereco))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">📍</div>
                                            <div>
                                                <span class="info-row-label">Endereço</span>
                                                <div class="info-row-val">@s.Endereco</div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.LinkOnline))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">🔗</div>
                                            <div>
                                                <span class="info-row-label">Link</span>
                                                <a href="@s.LinkOnline" target="_blank" class="servico-link">Acessar →</a>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.Descricao))
                                    {
                                        <p class="servico-desc">@s.Descricao</p>
                                    }

                                </div>

                                <div class="servico-actions">
                                    <button type="button" class="btn-edit" data-id="@s.Id" data-nome="@s.Nome"
                                            data-local="@s.LocalId" data-desc="@s.Descricao" data-contato="@s.Contato"
                                            data-atendimento="@s.Atendimento" data-link="@s.LinkOnline"
                                            data-sub="@s.SubcategoriaId">
                                        ✏️ Editar
                                    </button>
                                    <button type="button" class="btn-delete"
                                            onclick="abrirModalExcluir(@s.Id, '@s.Nome.Replace("'", "\\'")')">
                                        🗑 Excluir
                                    </button>
                                </div>

                            </div>
                        }
                    </div>
                </div>

                <!-- DRAWER DE EDIÇÃO -->
                <div class="edit-drawer" id="editDrawer">
                    <div class="drawer-card">

                        <div class="drawer-header">
                            <div class="drawer-header-left">
                                <div class="drawer-header-icon">✏️</div>
                                <div>
                                    <div class="drawer-title" id="drawerTitle">Editar serviço</div>
                                    <div class="drawer-sub" id="drawerSub">Atualize as informações</div>
                                </div>
                            </div>
                            <button class="drawer-close" onclick="fecharDrawer()">✕</button>
                        </div>

                        <form method="post" action="/Servico/Editar" id="formEditar">
                            <input type="hidden" name="Id" id="editId" />

                            <div class="drawer-body">

                                <div class="form-group">
                                    <label class="form-label" for="editNome">
                                        Nome do serviço <span class="req">*</span>
                                    </label>
                                    <input class="form-input" type="text" name="Nome" id="editNome"
                                           placeholder="Ex: Corte de cabelo masculino" required />
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="editSub">
                                        Subcategoria <span class="req">*</span>
                                    </label>
                                    <div class="select-wrap">
                                        <select class="form-select" name="SubcategoriaId" id="editSub">
                                            @foreach (var sub in (ViewBag.Subcategorias as List<Subcategoria>) ?? new
                                                                                                                                                                                                                                                                                                                List<Subcategoria>())
                                            {
                                                <option value="@sub.Id">@sub.Nome</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="editAtend">Tipo de atendimento</label>
                                    <div class="select-wrap">
                                        <select class="form-select" name="Atendimento" id="editAtend"
                                                onchange="atualizarCamposDinamicos()">
                                            <option value="Domicilio">🏠 Domicílio</option>
                                            <option value="Local">📍 Local</option>
                                            <option value="Online">💻 Online</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="campo-dinamico" id="campoLocal">
                                    <label class="form-label">Local de atendimento</label>

                                    <select class="form-select" name="LocalId" id="editLocal">
                                        @if (ViewBag.Locais != null)
                                        {
                                            foreach (var l in ViewBag.Locais)
                                            {
                                                <option value="@l.Id">@l.Endereco</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- Campo dinâmico: link online -->
                                <div class="campo-dinamico" id="campoLinkOnline">
                                    <label class="form-label" for="editLink">Link de acesso</label>
                                    <input class="form-input" type="url" name="LinkOnline" id="editLink"
                                           placeholder="https://meet.google.com/..." />
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="editContato">Contato</label>
                                    <input class="form-input" type="text" name="Contato" id="editContato"
                                           placeholder="(11) 91234-5678" />
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="editDesc">Descrição</label>
                                    <textarea class="form-textarea" name="Descricao" id="editDesc"
                                              placeholder="Descreva detalhes do serviço..."></textarea>
                                </div>

                            </div>

                            <div class="drawer-footer">
                                <button type="button" class="btn-cancelar-drawer" onclick="fecharDrawer()">
                                    Cancelar
                                </button>
                                <button type="submit" class="btn-salvar">
                                    💾 Salvar alterações
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

            </div><!-- /servicos-layout -->
        }

    </div>
</div>


<!-- MODAL EXCLUIR -->
<div class="modal-overlay" id="modalExcluir">
    <div class="modal-box">
        <div class="modal-icon">🗑️</div>
        <div class="modal-title">Excluir serviço?</div>
        <p class="modal-sub">
            Tem certeza que deseja excluir
            <span class="modal-name" id="modalNomeServico"></span>?
            Esta ação não pode ser desfeita.
        </p>
        <div class="modal-actions">
            <button class="btn-modal-cancel" onclick="fecharModal()">Cancelar</button>
            <a class="btn-modal-confirm" id="modalLinkExcluir" href="#">Sim, excluir</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var cardAtivo = null;
        var btnAtivo = null;

        /* -----------------------------------------------
           CLICK BOTÃO EDITAR
        ----------------------------------------------- */
        document.querySelectorAll(".btn-edit").forEach(btn => {

            btn.addEventListener("click", function () {

                abrirDrawer(
                    this.dataset.id,
                    this.dataset.nome || "",
                    this.dataset.desc || "",
                    this.dataset.contato || "",
                    this.dataset.atendimento || "",
                    this.dataset.link || "",
                    this.dataset.sub,
                    this.dataset.local,
                    this
                );

            });

        });

        /* -----------------------------------------------
           ABRIR DRAWER
        ----------------------------------------------- */
        function abrirDrawer(id, nome, descricao, contato, atendimento, linkOnline, subcategoriaId, localId, botao) {

            if (cardAtivo) cardAtivo.classList.remove('editando');
            if (btnAtivo) btnAtivo.classList.remove('ativo');

            cardAtivo = document.getElementById('card-' + id);
            btnAtivo = botao;

            if (cardAtivo) cardAtivo.classList.add('editando');
            if (btnAtivo) btnAtivo.classList.add('ativo');

            document.getElementById('editId').value = id;
            document.getElementById('editNome').value = nome;
            document.getElementById('editDesc').value = descricao;
            document.getElementById('editContato').value = contato;
            document.getElementById('editLink').value = linkOnline;

            // subcategoria
            var selSub = document.getElementById('editSub');
            if (selSub) {
                for (var i = 0; i < selSub.options.length; i++) {
                    if (selSub.options[i].value == subcategoriaId) {
                        selSub.selectedIndex = i;
                        break;
                    }
                }
            }

            // atendimento
            var selAtend = document.getElementById('editAtend');
            if (selAtend) {
                for (var j = 0; j < selAtend.options.length; j++) {
                    if (selAtend.options[j].value === atendimento) {
                        selAtend.selectedIndex = j;
                        break;
                    }
                }
            }

            // local
            var selLocal = document.getElementById('editLocal');
            if (selLocal && localId) {
                for (var i = 0; i < selLocal.options.length; i++) {
                    if (selLocal.options[i].value == localId) {
                        selLocal.selectedIndex = i;
                        break;
                    }
                }
            }

            document.getElementById('drawerTitle').textContent = nome;
            document.getElementById('drawerSub').textContent = 'Editando serviço';

            atualizarCamposDinamicos();

            document.getElementById('editDrawer').classList.add('open');
            document.getElementById('servicosLayout').classList.add('drawer-open');
        }

        /* -----------------------------------------------
           FECHAR DRAWER
        ----------------------------------------------- */
        function fecharDrawer() {
            document.getElementById('editDrawer').classList.remove('open');
            document.getElementById('servicosLayout').classList.remove('drawer-open');

            if (cardAtivo) cardAtivo.classList.remove('editando');
            if (btnAtivo) btnAtivo.classList.remove('ativo');

            cardAtivo = null;
            btnAtivo = null;
        }

        /* -----------------------------------------------
           CAMPOS DINÂMICOS
        ----------------------------------------------- */
        function atualizarCamposDinamicos() {
            var atend = document.getElementById('editAtend').value;

            var campoLink = document.getElementById('campoLinkOnline');
            var campoLocal = document.getElementById('campoLocal');

            if (campoLink)
                campoLink.classList.toggle('visivel', atend === 'Online');

            if (campoLocal)
                campoLocal.classList.toggle('visivel', atend === 'Local');
        }

        /* -----------------------------------------------
           MODAL EXCLUIR
        ----------------------------------------------- */
        function abrirModalExcluir(id, nome) {
            document.getElementById('modalNomeServico').textContent = '"' + nome + '"';
            document.getElementById('modalLinkExcluir').href = '/Servico/Excluir/' + id;
            document.getElementById('modalExcluir').classList.add('open');
        }

        function fecharModal() {
            document.getElementById('modalExcluir').classList.remove('open');
        }

        document.getElementById('modalExcluir')?.addEventListener('click', function (e) {
            if (e.target === this) fecharModal();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                fecharModal();
                fecharDrawer();
            }
        });
    </script>
}
