@model List<Servico>



@section Styles {
    <link rel="stylesheet" href="~/css/MeusServicos.css" />
}

@if (TempData["Sucesso"]?.ToString() == "cadastro_ok")
{
    <div class="alert-sucesso">
        Conta criada! Agora cadastre seu primeiro serviço.
    </div>
}

@functions {
    string GetBadgeClass(string atend)
    {
        if (atend == "Local") return "badge-local";
        if (atend == "Domicilio") return "badge-domicilio";
        if (atend == "Online") return "badge-online";
        return "badge-default";
    }
    string GetBadgeIcon(string atend)
    {
        if (atend == "Local") return "📍";
        if (atend == "Domicilio") return "🏠";
        if (atend == "Online") return "💻";
        return "📌";
    }
    string GetIniciais(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome)) return "?";
        var p = nome.Trim().Split(' ');
        string r = "";
        for (int i = 0; i < p.Length && i < 2; i++)
            if (p[i].Length > 0) r += char.ToUpper(p[i][0]);
        return r;
    }
}

<div class="servicos-page">

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert-sucesso">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert-erro">
            @TempData["Erro"]
        </div>
    }

    <!-- HERO -->
    <div class="servicos-hero">
        <div class="servicos-hero-dots"></div>
        <div class="servicos-hero-inner">
            <div>
                <span class="servicos-hero-label">Meu negócio</span>
                <h1 class="servicos-hero-title">Meus Serviços</h1>
                <p class="servicos-hero-sub">Gerencie, edite e organize tudo que você oferece.</p>
            </div>
            @if (Model.Count > 0)
            {
                <div class="servicos-hero-count">
                    <strong>@Model.Count</strong>
                    <span>@(Model.Count == 1 ? "serviço cadastrado" : "serviços cadastrados")</span>
                </div>
            }
        </div>
    </div>

    <!-- CONTEÚDO -->
    <div class="servicos-main">


        <div class="filtro-servicos">
            <button class="filtro-btn ativo" onclick="filtrarServicos('todos')">Todos</button>
            <button class="filtro-btn" onclick="filtrarServicos('ativos')">Ativos</button>
            <button class="filtro-btn" onclick="filtrarServicos('inativos')">Inativos</button>
        </div>
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>Nenhum serviço cadastrado</h3>
                <p>Crie seu primeiro serviço para aparecer para clientes e começar a receber agendamentos.</p>
                <a href="/Servico/Criar" class="btn-criar-primeiro">+ Criar meu primeiro serviço</a>
            </div>
        }
        else
        {
            <div class="servicos-topbar">
                <div class="servicos-topbar-title">Todos os serviços</div>
                <a href="/Servico/Criar" class="btn-novo">+ Novo serviço</a>
            </div>

            <div class="servicos-layout" id="servicosLayout">

                <!-- COLUNA DA LISTA -->
                <div>
                    <div class="servicos-grid" id="servicosGrid">
                        
                        @foreach (var s in Model)
                        {
                            <div class="servico-card @(s.Ativo ? "" : "inativo")" id="card-@s.Id">


                                <div class="servico-header">
                                  
                                    <h3>@s.Nome</h3>

                                    @if (s.Ativo)
                                    {
                                        <span class="badge-ativo">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inativo">Inativo</span>
                                    }

                                    <span class="badge-atendimento @GetBadgeClass(s.Atendimento)">
                                        @GetBadgeIcon(s.Atendimento) @s.Atendimento
                                    </span>
                                </div>

                                <div class="servico-body">

                                    <div class="info-row">
                                        <div class="info-row-icon">📂</div>
                                        <div>
                                            <span class="info-row-label">Categoria</span>
                                            <div class="info-row-val">@s.Categoria</div>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(s.Subcategoria))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">🏷️</div>
                                            <div>
                                                <span class="info-row-label">Subcategoria</span>
                                                <div class="info-row-val">@s.Subcategoria</div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.Contato))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">📞</div>
                                            <div>
                                                <span class="info-row-label">Contato</span>
                                                <div class="info-row-val">@s.Contato</div>
                                            </div>
                                        </div>
                                    }

                                    @if (s.Atendimento == "Local" && !string.IsNullOrEmpty(s.Endereco))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">📍</div>
                                            <div>
                                                <span class="info-row-label">Endereço</span>
                                                <div class="info-row-val">@s.Endereco</div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.LinkOnline))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">🔗</div>
                                            <div>
                                                <span class="info-row-label">Link</span>
                                                <a href="@s.LinkOnline" target="_blank" class="servico-link">Acessar →</a>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.Descricao))
                                    {
                                        <p class="servico-desc">@s.Descricao</p>
                                    }

                                </div>

                                <div class="servico-actions">
                                    <button type="button" class="btn-edit" @(s.Ativo ? "" : "disabled") data-id="@s.Id"
                                            data-nome="@s.Nome" data-local="@s.LocalId" data-desc="@s.Descricao"
                                            data-contato="@s.Contato" data-atendimento="@s.Atendimento" data-link="@s.LinkOnline"
                                            data-sub="@s.SubcategoriaId">
                                        ✏️ Editar
                                    </button>

                                    <button type="button" class="btn-delete" @(s.Ativo ? "" : "disabled")
                                            onclick="abrirModalAcao(@s.Id, '@s.Nome.Replace("'", "\\'")')">
                                        🗑 Remover
                                    </button>
                                </div>

                            </div>
                        }
                    </div>
                </div>

            </div><!-- /servicos-layout -->
        }

    </div>
</div>


<!-- MODAL EXCLUIR -->
<div class="modal-overlay" id="modalAcao">
    <div class="modal-box">

        <div class="modal-icon">⚠️</div>

        <div class="modal-title">Remover serviço?</div>

        <p class="modal-sub" id="modalTextoAcao"></p>

        <div class="modal-actions">
            <button onclick="fecharModal('modalAcao')" class="btn-cancelar">
                Cancelar
            </button>

            <a id="modalConfirmarAcao" class="btn-modal-confirm">
                Confirmar
            </a>
        </div>

    </div>
</div>

<div class="modal-overlay" id="modalServico">
    <div class="modal-drawer">

        <div class="drawer-header">
            <h3 id="modalServicoTitle">Editar serviço</h3>
            <button onclick="fecharModal('modalServico')">✕</button>
        </div>

        <form method="post" action="/Servico/Editar" id="formServicoModal">

            <input type="hidden" name="id" id="servicoId" />

            <div class="drawer-body">

                <input type="hidden" name="SubcategoriaId" id="editSubcategoriaId" />

                <div class="form-group">
                    <label class="form-label">Nome</label>
                    <input type="text" name="nome" id="editNome" class="form-input" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Descrição</label>
                    <textarea name="descricao" id="editDesc" class="form-textarea"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Contato</label>
                    <input type="text" name="contato" id="editContato" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Atendimento</label>
                    <select name="atendimento" id="editAtendimento" class="form-select">
                        <option value="Domicilio">🏠 Domicílio</option>
                        <option value="Local">📍 Local</option>
                        <option value="Online">💻 Online</option>
                    </select>
                </div>

                <!-- LOCAL -->
                <div id="editLocalDiv" class="form-group hidden">
                    <label class="form-label">Local</label>
                    <select name="localId" id="editLocal" class="form-select">
                        <option value="">Selecione</option>
                        @foreach (var l in ViewBag.Locais)
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    </select>
                </div>

                <!-- ONLINE -->
                <div id="editLinkDiv" class="form-group hidden">
                    <label class="form-label">Link online</label>
                    <input type="url" name="linkOnline" id="editLink" class="form-input" />
                </div>

            </div>
            <div class="drawer-footer">
                <button type="button" class="btn-cancelar-modal" onclick="fecharModal('modalServico')">
                    Cancelar
                </button>
                <button type="submit" class="btn-salvar">Salvar alterações</button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".btn-edit").forEach(btn => {
            btn.addEventListener("click", function () {

                const id = this.dataset.id;
                const nome = this.dataset.nome || "";
                const desc = this.dataset.desc || "";
                const contato = this.dataset.contato || "";
                const atendimento = this.dataset.atendimento || "";
                const link = this.dataset.link || "";
                const local = this.dataset.local;


                document.getElementById('servicoId').value = id;
                document.getElementById('editNome').value = nome;
                document.getElementById('editDesc').value = desc;
                document.getElementById('editContato').value = contato;
                document.getElementById('editLink').value = link;
                document.getElementById('editAtendimento').value = atendimento;

                if (local)
                    document.getElementById('editLocal').value = local;

                atualizarCamposDinamicos();

                abrirModal('modalServico');
            });
        });

        /* -----------------------------------------------
           CAMPOS DINÂMICOS
        ----------------------------------------------- */
        function atualizarCamposDinamicos() {

            const tipo = document.getElementById('editAtendimento').value;

            const localDiv = document.getElementById('editLocalDiv');
            const linkDiv = document.getElementById('editLinkDiv');

            if (tipo === 'Local') {
                localDiv.classList.remove('hidden');
                linkDiv.classList.add('hidden');
            }
            else if (tipo === 'Online') {
                linkDiv.classList.remove('hidden');
                localDiv.classList.add('hidden');
            }
            else {
                localDiv.classList.add('hidden');
                linkDiv.classList.add('hidden');
            }
        }

        document.getElementById('editAtendimento')
            ?.addEventListener('change', atualizarCamposDinamicos);
        /* -----------------------------------------------
           MODAL EXCLUIR 
        ----------------------------------------------- */
        function abrirModalExcluir(id, nome) {
            document.getElementById('modalNomeServico').textContent = '"' + nome + '"';
            document.getElementById('modalLinkExcluir').href = '/Servico/Excluir/' + id;
            abrirModal('modalExcluir');
        }

        function abrirModalAcao(id, nome) {

            const texto = `Este serviço pode ter agendamentos.

                                            Se tiver → será desativado  
                                            Se não tiver → será excluído`;

            document.getElementById('modalTextoAcao').innerText = texto;

            document.getElementById('modalConfirmarAcao')
                .href = '/Servico/Desativar/' + id;

            abrirModal('modalAcao');
        }

        /*----------------------
        setTimeout para alerts
        ------------------------*/

        setTimeout(() => {
            document.querySelectorAll('.alert-sucesso, .alert-erro')
                .forEach(el => {
                    el.style.opacity = '0';
                    el.style.transition = 'opacity .3s';
                    setTimeout(() => el.remove(), 300);
                });
        }, 3000);

        /*------------------------
        FILTRO
        ----------------------*/

        const botoesFiltro = document.querySelectorAll('.filtro-btn');

        botoesFiltro.forEach(btn => {
            btn.addEventListener('click', function () {

                // remove ativo de todos
                botoesFiltro.forEach(b => b.classList.remove('ativo'));

                // adiciona no clicado
                this.classList.add('ativo');

                const tipo = this.dataset.filtro;
                filtrarServicos(tipo);
            });
        });

        function filtrarServicos(tipo) {

            const cards = document.querySelectorAll('.servico-card');

            cards.forEach(card => {

                const inativo = card.classList.contains('inativo');

                if (tipo === 'todos') {
                    card.style.display = 'block';
                }
                else if (tipo === 'ativos') {
                    card.style.display = inativo ? 'none' : 'block';
                }
                else if (tipo === 'inativos') {
                    card.style.display = inativo ? 'block' : 'none';
                }

            });

        }


    </script>
}
