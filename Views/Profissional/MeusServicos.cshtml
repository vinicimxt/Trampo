@model List<Servico>

@section Styles {
    <link rel="stylesheet" href="~/css/PerfilPro.css" />
}

<div class="perfil-container">

    <div class="perfil-header">
        <h2>📦 Meus Serviços</h2>

        <a href="/Servico/Criar" class="btn-primary">
            ➕ Novo Serviço
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <p>Você ainda não cadastrou nenhum serviço.</p>
            <a href="/Servico/Criar" class="btn-primary">
                Criar primeiro serviço
            </a>
        </div>
    }
    else
    {
        <div class="servicos-grid">
            @foreach (var s in Model)
            {
                <div class="servico-card">

                    <div class="servico-header">
                        <h3>@s.Nome</h3>
                        <span class="badge">@s.Atendimento</span>
                    </div>

                    <div class="servico-body">
                        <p><b>Categoria:</b> @s.Categoria</p>
                        <p><b>Subcategoria:</b> @s.Subcategoria</p>

                        @if (!string.IsNullOrEmpty(s.Descricao))
                        {
                            <p class="desc">@s.Descricao</p>
                        }

                        @if (!string.IsNullOrEmpty(s.Contato))
                        {
                            <p>📞 @s.Contato</p>
                        }

                        @if (s.Atendimento == "Local")
                        {
                            <p>📍 @s.Endereco</p>
                        }

                        @if (!string.IsNullOrEmpty(s.LinkOnline))
                        {
                            <p>🔗 <a href="@s.LinkOnline" target="_blank">Acessar</a></p>
                        }
                    </div>

                    <div class="servico-actions">
                        <a asp-controller="Servico" asp-action="Editar" asp-route-id="@s.Id" class="btn-edit">
                            ✏️ Editar
                        </a>

                        <a asp-controller="Servico" asp-action="Excluir" asp-route-id="@s.Id"
                           class="btn-delete"
                           onclick="return confirm('Deseja excluir este serviço?')">
                            🗑 Excluir
                        </a>
                    </div>

                </div>
            }
        </div>
    }

</div>