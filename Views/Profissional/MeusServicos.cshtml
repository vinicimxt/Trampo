@model List<Servico>

<h2>Meus Serviços</h2>

<a href="/Servico/Criar">➕ Novo Serviço</a>

@if (Model.Count == 0)
{
    <p>Você ainda não cadastrou nenhum serviço.</p>
}
else
{
    foreach (var s in Model)
    {
        <div style="border:1px solid #ccc; margin:10px; padding:10px;">
            <h3>@s.Nome</h3>
            <p>@s.Descricao</p>
            <p><b>Contato:</b> @s.Contato</p>
        </div>
    }
}