@model List<Servico>

<h2>Meus Serviços</h2>

<a href="/Servico/Criar">➕ Novo Serviço</a>

@if (Model.Count == 0)
{
    <p>Você ainda não cadastrou nenhum serviço.</p>
}
else
{
    foreach (var s in Model)
    {
        <div style="border:1px solid #ccc; margin:10px; padding:10px; border-radius:10px;">
            
            <h3>@s.Nome</h3>

            <p><b>Categoria:</b> @s.Categoria</p>
            <p><b>Subcategoria:</b> @s.Subcategoria</p>

            <p>@s.Descricao</p>

            <p><b>Contato:</b> @s.Contato</p>

            <p><b>Atendimento:</b> @s.Atendimento</p>

            @if (s.Atendimento == "Domicilio")
            {
                <p><b>Raio:</b> @s.RaioAtendimento km</p>
            }

            @if (!string.IsNullOrEmpty(s.LinkOnline))
            {
                <p>🔗 Online: @s.LinkOnline</p>
            }

        </div>
    }
}

@foreach (var s in Model)
{
    <div>
        <h3>@s.Nome</h3>

        <a asp-controller="Servico" asp-action="Editar" asp-route-id="@s.Id">
            ✏️ Editar
        </a>

        <a asp-controller="Servico" asp-action="Excluir" asp-route-id="@s.Id">
            🗑 Excluir
        </a>
    </div>
}