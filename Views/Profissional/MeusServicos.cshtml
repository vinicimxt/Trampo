@model List<Servico>

@section Styles {
    <link rel="stylesheet" href="~/css/MeusServicos.css" />
}

@if (TempData["Sucesso"]?.ToString() == "cadastro_ok")
{
    <div class="alert-sucesso">
        Conta criada! Agora cadastre seu primeiro serviço.
    </div>
}

@functions {
    string GetBadgeClass(string atend)
    {
        if (atend == "Local") return "badge-local";
        if (atend == "Domicilio") return "badge-domicilio";
        if (atend == "Online") return "badge-online";
        return "badge-default";
    }
    string GetBadgeIcon(string atend)
    {
        if (atend == "Local") return "location_on";
        if (atend == "Domicilio") return "home";
        if (atend == "Online") return "laptop";
        return "place";
    }
    string GetBadgeLabel(string atend)
    {
        if (atend == "Local") return "Presencial";
        if (atend == "Domicilio") return "Domicílio";
        if (atend == "Online") return "Online";
        return atend;
    }
    string GetIniciais(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome)) return "?";
        var p = nome.Trim().Split(' ');
        string r = "";
        for (int i = 0; i < p.Length && i < 2; i++)
            if (p[i].Length > 0) r += char.ToUpper(p[i][0]);
        return r;
    }
}

<div class="servicos-page">

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert-sucesso">@TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert-erro">@TempData["Erro"]</div>
    }

    <!-- HERO -->
    <div class="servicos-hero">
        <div class="servicos-hero-dots"></div>
        <div class="servicos-hero-inner">
            <div>
                <span class="servicos-hero-label">Meu negócio</span>
                <h1 class="servicos-hero-title">Meus Serviços</h1>
                <p class="servicos-hero-sub">Gerencie, edite e organize tudo que você oferece.</p>
            </div>
            @if (Model.Count > 0)
            {
                <div class="servicos-hero-count">
                    <strong>@Model.Count</strong>
                    <span>@(Model.Count == 1 ? "serviço cadastrado" : "serviços cadastrados")</span>
                </div>
            }
        </div>
    </div>

    <!-- CONTEÚDO -->
    <div class="servicos-main">

        <!-- substitua os 3 botões de filtro por: -->
        <div class="filtro-servicos">
            <button aria-label="Todos meus serviços" class="filtro-btn ativo" data-filtro="todos" onclick="filtrarServicos('todos')">
                <span aria-hidden="true" class="material-symbols-rounded">list</span> Todos
            </button>
            <button aria-label="serviços ativos" class="filtro-btn" data-filtro="ativos" onclick="filtrarServicos('ativos')">
                <span aria-hidden="true" class="material-symbols-rounded">check_circle</span> Ativos
            </button>
            <button aria-label="serviços inativos" class="filtro-btn" data-filtro="inativos" onclick="filtrarServicos('inativos')">
                <span aria-hidden="true" class="material-symbols-rounded">cancel</span> Inativos
            </button>
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <span aria-hidden="true" class="material-symbols-rounded">inventory_2</span>
                </div>
                <h3>Nenhum serviço cadastrado</h3>
                <p>Crie seu primeiro serviço para aparecer para clientes e começar a receber agendamentos.</p>
                <a href="/Servico/Criar" class="btn-criar-primeiro">
                    <span aria-hidden="true" class="material-symbols-rounded">add</span>
                    Criar meu primeiro serviço
                </a>
            </div>
        }
        else
        {
            <div class="servicos-topbar">
                <div class="servicos-topbar-title">Todos os serviços</div>
                <a href="/Servico/Criar" class="btn-novo">
                    <span aria-hidden="true" class="material-symbols-rounded">add</span>
                    Novo serviço
                </a>
            </div>

            <div class="servicos-layout" id="servicosLayout">
                <div>
                    <div class="servicos-grid" id="servicosGrid">

                        @{
                            var servicosOrdenados = Model.OrderByDescending(s => s.Ativo).ToList();
                        }

                        @foreach (var s in servicosOrdenados)
                        {
                            <div class="servico-card @(s.Ativo ? "" : "inativo")" id="card-@s.Id">

                                <div class="servico-header">
                                    <h3>@s.Nome</h3>

                                    @if (s.Ativo)
                                    {
                                        <span class="badge-ativo">
                                            <span aria-hidden="true" class="material-symbols-rounded">check_circle</span>
                                            Ativo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-inativo">
                                            <span aria-hidden="true" class="material-symbols-rounded">cancel</span>
                                            Inativo
                                        </span>
                                    }

                                    <span class="badge-atendimento @GetBadgeClass(s.Atendimento)">
                                        <span class="material-symbols-rounded">@GetBadgeIcon(s.Atendimento)</span>
                                        @GetBadgeLabel(s.Atendimento)
                                    </span>
                                </div>

                                <div class="servico-body">

                                    <div class="info-row">
                                        <div class="info-row-icon">
                                            <span aria-hidden="true" class="material-symbols-rounded">folder</span>
                                        </div>
                                        <div>
                                            <span class="info-row-label">Categoria</span>
                                            <div class="info-row-val">@s.Categoria</div>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(s.Subcategoria))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">
                                                <span aria-hidden="true" class="material-symbols-rounded">label</span>
                                            </div>
                                            <div>
                                                <span class="info-row-label">Subcategoria</span>
                                                <div class="info-row-val">@s.Subcategoria</div>
                                            </div>
                                        </div>
                                    }

                                    @if (s.Atendimento == "Local" && !string.IsNullOrEmpty(s.Endereco))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">
                                                <span aria-hidden="true" class="material-symbols-rounded">location_on</span>
                                            </div>
                                            <div>
                                                <span class="info-row-label">Endereço</span>
                                                <div class="info-row-val">@s.Endereco</div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.LinkOnline))
                                    {
                                        <div class="info-row">
                                            <div class="info-row-icon">
                                                <span aria-hidden="true" class="material-symbols-rounded">link</span>
                                            </div>
                                            <div>
                                                <span class="info-row-label">Link</span>
                                                <a href="@s.LinkOnline" target="_blank" class="servico-link">
                                                    Acessar
                                                    <span aria-hidden="true" class="material-symbols-rounded"
                                                          style="font-size:14px;">open_in_new</span>
                                                </a>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(s.Descricao))
                                    {
                                        <p class="servico-desc">@s.Descricao</p>
                                    }

                                </div>

                                <div class="servico-actions">
                                    <button aria-label="Editar serviço" type="button" class="btn-edit" @(s.Ativo ? "" : "disabled") data-id="@s.Id"
                                            data-nome="@s.Nome" data-local="@s.LocalId" data-desc="@s.Descricao"
                                            data-atendimento="@s.Atendimento" data-link="@s.LinkOnline" data-sub="@s.SubcategoriaId"
                                            data-hora-inicio="@s.HoraInicio" data-hora-fim="@s.HoraFim" data-dias="@s.DiasTexto"
                                            data-tipo-preco="@s.TipoPreco" data-preco="@s.PrecoBase">
                                        <span aria-hidden="true" class="material-symbols-rounded">edit</span>
                                        Editar
                                    </button>

                                    <button aria-label="Remover serviço" type="button" class="btn-delete" @(s.Ativo ? "" : "disabled")
                                            onclick="abrirModalAcao(@s.Id, '@s.Nome.Replace("'", "\\'")')">
                                        <span aria-hidden="true" class="material-symbols-rounded">delete</span>
                                        Remover
                                    </button>
                                </div>

                            </div>
                        }
                    </div>
                </div>
            </div>
        }

    </div>
</div>


<!-- MODAL REMOVER -->
<div class="modal-overlay" id="modalAcao">
    <div class="modal-box">
        <div class="modal-icon">
            <span aria-hidden="true" class="material-symbols-rounded" style="font-size:2.8rem;color:#ef4444;">warning</span>
        </div>
        <div class="modal-title">Remover serviço?</div>
        <p class="modal-sub" id="modalTextoAcao"></p>
        <div class="modal-actions">
            <button aria-label="Cancelar" onclick="fecharModal('modalAcao')" class="btn-cancelar">
                Cancelar
            </button>
            <a aria-label="Confirmar" id="modalConfirmarAcao" class="btn-modal-confirm">
                <span class="material-symbols-rounded">check</span>
                Confirmar
            </a>
        </div>
    </div>
</div>


<!-- MODAL EDITAR (drawer) -->
<div class="modal-overlay" id="modalServico">
    <div class="modal-drawer">

        <div class="drawer-header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span aria-hidden="true" class="material-symbols-rounded" style="color:var(--accent);font-size:20px;">edit</span>
                <h3 id="modalServicoTitle">Editar serviço</h3>
            </div>
            <button onclick="fecharModal('modalServico')" aria-label="Fechar">
                <span aria-hidden="true" class="material-symbols-rounded">close</span>
            </button>
        </div>

        <form method="post" action="/Servico/Editar" id="formServicoModal">
            <input type="hidden" name="id" id="servicoId" />

            <div class="drawer-body">
                <input type="hidden" name="SubcategoriaId" id="editSubcategoriaId" />

                <div class="form-group">
                    <label class="form-label">Nome</label>
                    <input type="text" name="nome" id="editNome" class="form-input" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Descrição</label>
                    <textarea name="descricao" id="editDesc" class="form-textarea"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Atendimento</label>
                    <select name="atendimento" id="editAtendimento" class="form-select">
                        <option value="Domicilio">Domicílio</option>
                        <option value="Local">Presencial</option>
                        <option value="Online">Online</option>
                    </select>
                </div>

                <div class="form-group">

                    <label class="form-label">
                        Tipo de preço
                    </label>

                    <select name="TipoPreco" id="editTipoPreco" class="form-select">

                        <option value="Fixo">
                            Preço fixo
                        </option>

                        <option value="Combinar">
                            A combinar
                        </option>

                    </select>

                </div>

                <div class="form-group" id="editPrecoDiv">

                    <label class="form-label">
                        Preço do serviço
                    </label>

                    <input type="number" step="0.01" min="0" name="PrecoBase" id="editPreco" class="form-input"
                           placeholder="Ex: 80.00" />

                </div>

                <!-- LOCAL -->
                <div id="editLocalDiv" class="form-group hidden">
                    <label class="form-label">Local</label>
                    <select name="localId" id="editLocal" class="form-select">
                        <option value="">Selecione</option>
                        @foreach (var l in ViewBag.Locais)
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    </select>
                </div>

                <!-- ONLINE -->
                <div id="editLinkDiv" class="form-group hidden">
                    <label class="form-label">Link online</label>
                    <input type="url" name="linkOnline" id="editLink" class="form-input"
                           placeholder="https://meet.google.com/..." />
                </div>

                <div class="form-group">
                    <label class="form-label">Dias de atendimento</label>
                    <div class="dias-pills" id="diasPillsEdit">
                        <button aria-label="Segunda" type="button" class="dia-pill" data-val="1" onclick="toggleDiaEdit(this)">Seg</button>
                        <button aria-label="Terça" type="button" class="dia-pill" data-val="2" onclick="toggleDiaEdit(this)">Ter</button>
                        <button aria-label="Quarta" type="button" class="dia-pill" data-val="3" onclick="toggleDiaEdit(this)">Qua</button>
                        <button aria-label="Quinta" type="button" class="dia-pill" data-val="4" onclick="toggleDiaEdit(this)">Qui</button>
                        <button aria-label="Sexta" type="button" class="dia-pill" data-val="5" onclick="toggleDiaEdit(this)">Sex</button>
                        <button aria-label="Sábado" type="button" class="dia-pill" data-val="6" onclick="toggleDiaEdit(this)">Sáb</button>
                        <button aria-label="Domingo" type="button" class="dia-pill" data-val="0" onclick="toggleDiaEdit(this)">Dom</button>
                    </div>
                </div>

                <input type="hidden" name="diasSemana" id="diasSemanaEdit" />

                <div class="form-row-horario">
                    <div class="form-group">
                        <label class="form-label">Horário de início</label>
                        <input type="time" name="horaInicio" id="editHoraInicio" class="form-input form-time" />
                    </div>
                    <div class="time-separator">até</div>
                    <div class="form-group">
                        <label class="form-label">Horário de fim</label>
                        <input type="time" name="horaFim" id="editHoraFim" class="form-input form-time" />
                    </div>
                </div>

            </div>

            <div class="drawer-footer">
                <button type="button" class="btn-cancelar-modal" onclick="fecharModal('modalServico')">
                    Cancelar
                </button>
                <button type="submit" class="btn-salvar">
                    <span aria-hidden="true" class="material-symbols-rounded">save</span>
                    Salvar alterações
                </button>
            </div>

        </form>
    </div>
</div>


@section Scripts {
    <script>
        /* abrir drawer de edição */
        document.querySelectorAll('.btn-edit').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.getElementById('servicoId').value = this.dataset.id;
                document.getElementById('editNome').value = this.dataset.nome || '';
                document.getElementById('editDesc').value = this.dataset.desc || '';
                document.getElementById('editLink').value = this.dataset.link || '';
                document.getElementById('editAtendimento').value = this.dataset.atendimento || '';

                document.getElementById('editTipoPreco').value =
                    this.dataset.tipoPreco || 'Combinar';

                document.getElementById('editPreco').value =
                    this.dataset.preco || '';

                var local = this.dataset.local;
                if (local) document.getElementById('editLocal').value = local;

                atualizarCamposDinamicos();
                preencherDisponibilidade(
                    this.dataset.dias || '',
                    this.dataset.horaInicio || '',
                    this.dataset.horaFim || ''
                );
                abrirModal('modalServico');
            });
        });

        /* campos dinâmicos */
        function atualizarCamposDinamicos() {

            var atendimento =
                document.getElementById('editAtendimento').value;

            var tipoPreco =
                document.getElementById('editTipoPreco').value;

            var localDiv =
                document.getElementById('editLocalDiv');

            var linkDiv =
                document.getElementById('editLinkDiv');

            var precoDiv =
                document.getElementById('editPrecoDiv');

            localDiv.classList.toggle(
                'hidden',
                atendimento !== 'Local'
            );

            linkDiv.classList.toggle(
                'hidden',
                atendimento !== 'Online'
            );

            precoDiv.classList.toggle(
                'hidden',
                tipoPreco !== 'Fixo'
            );
        }
        document.getElementById('editAtendimento')
            ?.addEventListener('change', atualizarCamposDinamicos);
            
        document.getElementById('editTipoPreco')
            ?.addEventListener('change', atualizarCamposDinamicos);

        /* modal remover */
        function abrirModalAcao(id, nome) {
            document.getElementById('modalTextoAcao').innerText =
                'Este serviço pode ter agendamentos.\nSe tiver → será desativado.\nSe não tiver → será excluído.';
            document.getElementById('modalConfirmarAcao').href = '/Servico/Desativar/' + id;
            abrirModal('modalAcao');
        }

        /* auto-hide alerts */
        setTimeout(function () {
            document.querySelectorAll('.alert-sucesso, .alert-erro').forEach(function (el) {
                el.style.transition = 'opacity .3s';
                el.style.opacity = '0';
                setTimeout(function () { el.remove(); }, 300);
            });
        }, 3000);

        /* filtros */
        document.querySelectorAll('.filtro-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.filtro-btn')
                    .forEach(function (b) { b.classList.remove('ativo'); });
                this.classList.add('ativo');
            });
        });

        function filtrarServicos(tipo) {
            document.querySelectorAll('.servico-card').forEach(function (card) {
                var inativo = card.classList.contains('inativo');
                if (tipo === 'todos') card.style.display = '';
                else if (tipo === 'ativos') card.style.display = inativo ? 'none' : '';
                else if (tipo === 'inativos') card.style.display = inativo ? '' : 'none';
            });
        }

        /* preencher disponibilidade no drawer */
        var diasSelecionadosEdit = [];

        function preencherDisponibilidade(dias, horaInicio, horaFim) {
            diasSelecionadosEdit = [];
            document.querySelectorAll('#diasPillsEdit .dia-pill')
                .forEach(function (b) { b.classList.remove('ativo'); });

            if (dias && dias.trim()) {
                dias.split(',').forEach(function (d) {
                    d = d.trim();
                    var btn = document.querySelector('#diasPillsEdit .dia-pill[data-val="' + d + '"]');
                    if (btn) { btn.classList.add('ativo'); diasSelecionadosEdit.push(d); }
                });
            }
            document.getElementById('diasSemanaEdit').value = diasSelecionadosEdit.join(',');
            document.getElementById('editHoraInicio').value = horaInicio || '';
            document.getElementById('editHoraFim').value = horaFim || '';
        }

        function toggleDiaEdit(btn) {
            btn.classList.toggle('ativo');
            diasSelecionadosEdit = [];
            document.querySelectorAll('#diasPillsEdit .dia-pill.ativo')
                .forEach(function (x) { diasSelecionadosEdit.push(x.dataset.val); });
            document.getElementById('diasSemanaEdit').value = diasSelecionadosEdit.join(',');
        }
    </script>
}
