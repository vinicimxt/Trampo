@section Styles {
    <link rel="stylesheet" href="~/css/PerfilPro.css" />
}

<div class="perfil-container">

    <div class="perfil-header">
        <h1>👤 Meu Painel</h1>
        <p>Gerencie seus serviços, agendamentos e desempenho</p>
    </div>

    <div class="perfil-grid">
        @if (ViewBag.TotalServicos == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>Nenhum serviço ainda</h3>
                <p>Comece criando seu primeiro serviço para aparecer para clientes.</p>
                <a href="/Servico/Criar" class="btn-primary">Criar serviço</a>
            </div>
        }
        <a href="/Profissional/MeusServicos" class="perfil-card">
            <div class="card-icon">📦</div>
            <div class="card-content">
                <h3>Serviços</h3>
                <p>Gerencie seus serviços cadastrados</p>
            </div>
            <span class="card-arrow">→</span>
        </a>

        <a href="/Local/Lista" class="perfil-card">
            <div class="card-icon">📍</div>
            <div class="card-content">
                <h3>Locais</h3>
                <p>Configure seus locais de atendimento</p>
            </div>
            <span class="card-arrow">→</span>
        </a>

        <a href="/Agendamento/Recebidos" class="perfil-card">
            <div class="card-icon">📥</div>

            <div class="card-content">
                <h3>Agendamentos</h3>
                <p>Veja e gerencie seus pedidos</p>
            </div>

            @if (ViewBag.PedidosPendentes > 0)
            {
                <span class="badge">@ViewBag.PedidosPendentes</span>
            }

            <span class="card-arrow">→</span>
        </a>

        <a href="/Profissional/Dashboard" class="perfil-card destaque">
            <div class="card-icon">📊</div>
            <div class="card-content">
                <h3>Dashboard</h3>
                <p>Acompanhe seus resultados</p>
            </div>
            <span class="card-arrow">→</span>
        </a>

    </div>

</div>

@section Scripts {
    <script src="~/js/PerfilPro.js"></script>
}