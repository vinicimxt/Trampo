@model List<BD_TRAMPO.Servico>

<link rel="stylesheet" href="~/css/profissionais.css" />

<section class="profissionais-container">

    <h2 class="titulo-pagina">Serviços disponíveis</h2>

    <div class="grid-profissionais">

        @foreach (var item in Model)
        {
            <div class="card-servico">

                <div class="card-header">
                    <h3>@item.Nome</h3>
                    <span class="categoria">@item.Categoria</span>
                </div>

                <p class="profissional">
                    👤 @item.NomeProfissional
                </p>

                <p class="descricao">
                    @item.Descricao
                </p>

                <div class="info">
                    <span>📂 @item.Subcategoria</span>

                    <span class="atendimento">
                        @if (item.Atendimento == "Domicilio")
                        {
                            <span>🏠 Domicílio</span>
                        }
                        else if (item.Atendimento == "Local")
                        {
                            <span>📍 Local</span>
                        }
                        else if (item.Atendimento == "Online")
                        {
                            <span>💻 Online</span>
                        }
                    </span>
                </div>

                <div class="footer-card">
                    <span class="contato">📞 @item.Contato</span>

                    <a href="/Agendamento/novo?servicoId=@item.Id" 
                       class="btn-agendar">
                        Agendar
                    </a>
                </div>

            </div>
        }

    </div>

</section>

<script src="~/js/profissionais.js"></script>