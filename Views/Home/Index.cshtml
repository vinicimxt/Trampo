<section class="cta">
    <div class="container-ap">
        <h2>Pronto para agendar?</h2>
        <a href="#" class="btn-primary">Começar agora</a>
    </div>
</section>



<footer class="footer">
    <p>© 2026 Xamou - Todos os direitos reservados</p>
</footer>
@section Scripts {
    <script src="~/js/home.js"></script>
}