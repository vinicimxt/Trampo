@{
    ViewData["Title"] = "Home Page";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css?v=1" />
}
<section class="hero">
    <div class="hero-container">

        <!-- TEXTO -->
        <div class="hero-left">
            <span class="badge">● Mais de 5.000 profissionais disponíveis</span>

            <h1>
                Agende serviços<br>
                <span>perto de você</span><br>
                em poucos cliques
            </h1>

            <p>
                Encontre profissionais e empresas disponíveis para o horário que você precisa.
            </p>

            <div class="search-box">
                <input type="text" placeholder="Que serviço você precisa?" />
                <input type="text" placeholder="Sua localização" />
                <button>Buscar</button>
            </div>

            <div class="popular">
                Popular: Corte de cabelo • Manicure • Lava rápido
            </div>

        </div>

        <!-- VISUAL -->
        <div class="hero-right">
            <div class="phone-mock">
                <div class="phone-header"></div>

                <div class="item">Corte de cabelo - Hoje 14h</div>
                <div class="item">Manicure - Amanhã</div>
                <div class="item">Lava rápido - Sexta</div>

                <button class="btn-novo">+ Novo</button>
            </div>
        </div>

    </div>
</section>



<section class="stats">
    <div class="container-ap stats-grid">

        <div class="stat">
            <h2>12k+</h2>
            <p>Agendamentos</p>
        </div>

        <div class="stat">
            <h2>850+</h2>
            <p>Profissionais</p>
        </div>

        <div class="stat">
            <h2>4.9</h2>
            <p>Avaliação média</p>
        </div>

    </div>
</section>

<section class="services">
    <div class="container-ap">

        <div class="section-header">
            <span>Serviços</span>
            <h2>Encontre o que você precisa</h2>
            <p>Profissionais disponíveis na sua região</p>
        </div>

        <div class="services-grid">

            <div class="service-card">
                <div class="icon">✂️</div>
                <h3>Corte de cabelo</h3>
                <p>Barbearia • 4.9 ⭐</p>
                <button>Agendar</button>
            </div>

            <div class="service-card">
                <div class="icon">💅</div>
                <h3>Manicure</h3>
                <p>Studio Nails • 4.8 ⭐</p>
                <button>Agendar</button>
            </div>

            <div class="service-card">
                <div class="icon">🚗</div>
                <h3>Lava Rápido</h3>
                <p>LavaMax • 4.7 ⭐</p>
                <button>Agendar</button>
            </div>

        </div>
    </div>
</section>

<section class="how">
    <div class="container-ap">

        <div class="section-header">
            <span>Simples</span>
            <h2>Como funciona</h2>
        </div>

        <div class="steps">

            <div class="step">
                <div class="circle">1</div>
                <h3>Busque</h3>
                <p>Encontre serviços próximos</p>
            </div>

            <div class="step">
                <div class="circle">2</div>
                <h3>Escolha</h3>
                <p>Veja avaliações e horários</p>
            </div>

            <div class="step">
                <div class="circle">3</div>
                <h3>Agende</h3>
                <p>Confirme em segundos</p>
            </div>

        </div>
    </div>
</section>

