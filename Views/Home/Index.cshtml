@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css?v=4" />
}

<!-- =====================================================
     HERO
===================================================== -->
<section id="home" class="hero">
    <div class="hero-container">

        <div class="hero-left">
            <span class="badge">
                <span class="material-symbols-rounded icon-fill" style="font-size:14px;">verified</span>
                Mais de 5.000 profissionais disponíveis
            </span>

            <h1>
                Agende serviços<br>
                <span>perto de você</span><br>
                em poucos cliques
            </h1>

            <p>
                Encontre profissionais e empresas disponíveis para o horário que você precisa.
            </p>

            <form method="get" action="/Profissional/Lista" class="search-box">
                <div class="search-field">
                    <span class="material-symbols-rounded">search</span>
                    <input type="text" name="busca" placeholder="Qual serviço você precisa?" required />
                </div>

                <div class="divider"></div>

                <div class="search-field">
                    <span class="material-symbols-rounded">location_on</span>
                    <input type="text" name="localizacao" placeholder="Sua localização" />
                </div>

                <button type="submit" class="btn-search">
                    <span class="material-symbols-rounded" style="font-size:16px;">search</span>
                    Buscar
                </button>
            </form>

            <div class="popular">
                Popular: Corte de cabelo • Manicure • Lava rápido
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-visual">
                <div class="card card-main">
                    <h3>Barbearia Silva</h3>
                    <p>Hoje • 14:00</p>
                    <span class="status">Disponível</span>
                </div>
                <div class="card card-1">
                    <div class="card-float">
                        <p>Manicure</p>
                        <small>Amanhã • 10:30</small>
                    </div>
                </div>
                <div class="card card-2">
                    <div class="card-float">
                        <p>Faxina</p>
                        <small>Domingo • 08:00</small>
                    </div>
                </div>
                <div class="card card-3">
                    <div class="card-float">⭐ 4.9 Avaliação</div>
                </div>
            </div>
        </div>

    </div>
</section>


<!-- =====================================================
     SOBRE NÓS
===================================================== -->
<section id="about" class="about">
    <div class="container-ap">
        <div class="about-grid">

            <!-- TEXTO -->
            <div class="about-content">
                <span class="about-tag">
                    <span class="material-symbols-rounded" style="font-size:14px;">info</span>
                    Sobre a plataforma
                </span>

                <h2 class="about-title">
                    Conectando pessoas a profissionais de forma simples e rápida
                </h2>

                <p class="about-desc">
                    O Trampo nasceu com a missão de facilitar o acesso a serviços do dia a dia.
                    Aqui, você encontra profissionais confiáveis, agenda com poucos cliques e
                    acompanha tudo em um só lugar.
                </p>

                <p class="about-desc">
                    Eliminamos a burocracia e aproximamos quem precisa de quem faz,
                    criando uma experiência moderna, prática e segura.
                </p>

                <div class="about-features">
                    <span class="about-feature-chip">
                        <span class="material-symbols-rounded">bolt</span>
                        Agendamento rápido
                    </span>
                    <span class="about-feature-chip">
                        <span class="material-symbols-rounded">handshake</span>
                        Conexão direta
                    </span>
                    <span class="about-feature-chip">
                        <span class="material-symbols-rounded">shield</span>
                        Mais segurança
                    </span>
                </div>
            </div>

            <!-- IMAGEM -->
            <div class="about-image">
                <img src="~/assets/imagens/servicos/barbeiro.jpg" alt="Profissional em atendimento" />
            </div>

        </div>
    </div>
</section>



<!-- =====================================================
     DIFERENCIAIS
===================================================== -->
<section id="why" class="why">
    <div class="container-ap">

        <div class="section-header fade-up">
            <span class="section-label">
                <span class="material-symbols-rounded" style="font-size:14px;">workspace_premium</span>
                Por que o Trampo?
            </span>
            <h2>A plataforma feita para<br>simplificar o seu dia</h2>
            <p>Transparência, segurança e praticidade do primeiro contato até o pagamento.</p>
        </div>

        <div class="why-grid">

            <div class="why-card fade-up">
                <div class="why-icon">
                    <span class="material-symbols-rounded icon-fill">verified_user</span>
                </div>
                <div class="why-body">
                    <h3>Profissionais verificados</h3>
                    <p>Todo profissional passa por verificação de identidade e análise de reputação antes de aparecer na plataforma. Você contrata com confiança.</p>
                    <span class="why-tag">
                        <span class="material-symbols-rounded" style="font-size:12px;">check_circle</span>
                        100% verificado
                    </span>
                </div>
            </div>

            <div class="why-card fade-up" style="transition-delay:.08s">
                <div class="why-icon">
                    <span class="material-symbols-rounded icon-fill">bolt</span>
                </div>
                <div class="why-body">
                    <h3>Agendamento em segundos</h3>
                    <p>Sem ligações, sem espera. Escolha o serviço, veja a disponibilidade em tempo real e confirme o agendamento com um clique.</p>
                    <span class="why-tag">
                        <span class="material-symbols-rounded" style="font-size:12px;">timer</span>
                        Média de 45 segundos
                    </span>
                </div>
            </div>

            <div class="why-card fade-up" style="transition-delay:.12s">
                <div class="why-icon">
                    <span class="material-symbols-rounded icon-fill">star</span>
                </div>
                <div class="why-body">
                    <h3>Avaliações reais</h3>
                    <p>Todas as avaliações são de clientes reais que usaram o serviço. Nenhuma nota é fabricada — você sempre sabe o que esperar.</p>
                    <span class="why-tag">
                        <span class="material-symbols-rounded" style="font-size:12px;">grade</span>
                        Avaliação 4.9 / 5.0
                    </span>
                </div>
            </div>

            <div class="why-card fade-up" style="transition-delay:.16s">
                <div class="why-icon">
                    <span class="material-symbols-rounded icon-fill">support_agent</span>
                </div>
                <div class="why-body">
                    <h3>Suporte humano</h3>
                    <p>Tivemos algum problema? Nossa equipe está disponível para te ajudar via chat em menos de 5 minutos, todos os dias.</p>
                    <span class="why-tag">
                        <span class="material-symbols-rounded" style="font-size:12px;">schedule</span>
                        Suporte 7 dias por semana
                    </span>
                </div>
            </div>

        </div>

    </div>
</section>


<!-- =====================================================
     COMO FUNCIONA
===================================================== -->
<section id="how" class="how">
    <div class="container-ap">

        <div class="section-header fade-up">
            <span class="section-label">
                <span class="material-symbols-rounded" style="font-size:14px;">help_outline</span>
                Simples e rápido
            </span>
            <h2>Como funciona</h2>
            <p>Um jeito diferente para cada lado da plataforma.</p>
        </div>

        <div class="tab-switcher fade-up">
            <button class="tab-btn active" onclick="switchTab('cliente', this)">
                <span class="material-symbols-rounded" style="font-size:18px;">person</span>
                Sou cliente
            </button>
            <button class="tab-btn" onclick="switchTab('profissional', this)">
                <span class="material-symbols-rounded" style="font-size:18px;">engineering</span>
                Sou profissional
            </button>
        </div>

        <!-- Aba cliente -->
        <div class="tab-content active" id="tab-cliente">
            <div class="steps">

                <div class="step fade-up">
                    <div class="step-num">1</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">search</span>
                    </div>
                    <h3>Busque o serviço</h3>
                    <p>Digite o que você precisa e sua cidade. Veja todos os profissionais disponíveis perto de você com avaliações e preços.</p>
                </div>

                <div class="step-arrow">
                    <span class="material-symbols-rounded">arrow_forward</span>
                </div>

                <div class="step fade-up" style="transition-delay:.10s">
                    <div class="step-num">2</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">calendar_month</span>
                    </div>
                    <h3>Escolha e agende</h3>
                    <p>Veja a disponibilidade em tempo real, compare profissionais e confirme o horário que encaixa melhor na sua rotina.</p>
                </div>

                <div class="step-arrow">
                    <span class="material-symbols-rounded">arrow_forward</span>
                </div>

                <div class="step fade-up" style="transition-delay:.20s">
                    <div class="step-num">3</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">check_circle</span>
                    </div>
                    <h3>Pronto — aproveite!</h3>
                    <p>Receba a confirmação, acompanhe pelo app e, após o serviço, avalie o profissional. Simples assim.</p>
                </div>

            </div>
        </div>

        <!-- Aba profissional -->
        <div class="tab-content" id="tab-profissional">
            <div class="steps">

                <div class="step fade-up">
                    <div class="step-num">1</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">edit_note</span>
                    </div>
                    <h3>Crie seu perfil</h3>
                    <p>Cadastre-se gratuitamente, adicione seus serviços, defina preços e configure sua agenda em menos de 10 minutos.</p>
                </div>

                <div class="step-arrow">
                    <span class="material-symbols-rounded">arrow_forward</span>
                </div>

                <div class="step fade-up" style="transition-delay:.10s">
                    <div class="step-num">2</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">notifications_active</span>
                    </div>
                    <h3>Receba pedidos</h3>
                    <p>Clientes encontram seu perfil, verificam sua agenda e solicitam serviços. Você recebe a notificação e confirma em segundos.</p>
                </div>

                <div class="step-arrow">
                    <span class="material-symbols-rounded">arrow_forward</span>
                </div>

                <div class="step fade-up" style="transition-delay:.20s">
                    <div class="step-num">3</div>
                    <div class="step-icon-wrap">
                        <span class="material-symbols-rounded">payments</span>
                    </div>
                    <h3>Ganhe mais</h3>
                    <p>Atenda, receba sua avaliação e construa reputação. Quanto mais estrelas, mais visibilidade — e mais clientes chegando até você.</p>
                </div>

            </div>
        </div>

    </div>
</section>


